@page "/register"
@rendermode InteractiveServer

@using System.Security.Cryptography
@using System.Text
@using PimpYourBlech_ClassLibrary.Exceptions
@using PimpYourBlech_ClassLibrary.Services.Admin
@using PimpYourBlech_ClassLibrary.Services.CustomerCommunication
@using TestAutoKonfigurator.Session
@inject IAdminService AdminService
@inject IUserSession UserSession
@inject NavigationManager Nav

<div class="registration-container">

    <h3 class="headline">Registrierung</h3>

    <img src="benutzer.png" alt="HomeBild" class="user-image" />

<div class="mb-3">
    <label class="form-label">Vorname:</label>
    <input class="form-control" @bind="firstName"/>
</div>

<div class="mb-3">
    <label class="form-label">Nachname:</label>
    <input class="form-control" @bind="lastName"/>
</div>

<div class="mb-3">
    <label class="form-label">Telefon:</label>
    <input class="form-control" @bind="phone"/>
</div>

<h4>E-Mail</h4>

<div class="mb-3">
    <label class="form-label">E-Mail Adresse:</label>
    <input class="form-control" @bind="email"/>
</div>

<div class="mb-3">
    <label class="form-label">E-Mail Adresse bestätigen:</label>
    <input class="form-control" @bind="emailConfirm"/>
</div>

<h4>Account-Daten</h4>

<div class="mb-3">
    <label class="form-label">Username:</label>
    <input class="form-control" @bind="username"/>
</div>

<div class="mb-3">
    <label class="form-label">Passwort:</label>
    <input class="form-control" type = "password" @bind="password"/>
</div>



<br />
<div class="d-flex gap-2">
<button class="btn btn-primary" @onclick="RegisterCustomer">Registrieren</button>
<button class="btn btn-secondary" @onclick="Cancel">Abbrechen</button>
</div>

@code {
    private string firstName = "";
    private string lastName = "";
    private string phone = "";
    private string email = "";
    private string emailConfirm = "";
    private string username = "";
    private string password = "";

    private string ErrorMessage = "";
    private string SuccessMessage = "";

    private void RegisterCustomer()
    {
        ErrorMessage = "";
        SuccessMessage = "";

        try
        {
            EmailServices.IsValid(email);
            EmailServices.ConfirmRegistrationChecker(email, emailConfirm);
        }
        catch (WrongInputException ex)
        {
            ErrorMessage = ex.Message;
            return;
        }

        try
        {
            AdminService.isUsernameAvailable(username);
        }
        catch (UsernameNotAvailableException ex)
        {
            ErrorMessage = ex.Message;
            return;
        }

        var hash = Convert.ToBase64String(
            SHA256.HashData(Encoding.UTF8.GetBytes(password ?? ""))
        );

        AdminService.Register(firstName, lastName, username, hash, phone, email);
        SuccessMessage = "Registrierung erfolgreich. Bitte melde dich an.";
    }

    private void Cancel()
    {
        Nav.NavigateTo("/");
    }
}

<style>
    body {
        background-image: url("/Wallpaper.png");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        margin: 0;
        padding: 0;
        backdrop-filter: blur(10px);
    }

    .headline {
        font-family: Bahnschrift;
        color: white;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.7);
    }

    .registration-container {
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 12px;
        width: 55%;
        height: 100%;
        padding: 25px;
        background: rgba(0, 0, 0, 0.25);
        backdrop-filter: blur(8px); 
        -webkit-backdrop-filter: blur(8px);
        border-radius: 18px;
        border: 1px solid rgba(255, 0, 0, 0.25);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.6);
    }

    .user-image {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 2px solid rgba(255, 0, 0, 0.5);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.8);
    }

    .text-input {
        width: 240px;
        height: 38px;
        padding: 6px;
        font-family: Bahnschrift;
        text-align: center;
        background-color: rgba(20, 0, 0, 0.65); 
        color: white;
        border-radius: 10px;
        border: 2px solid rgba(255, 0, 0, 0.6);
        outline: none;
        transition: 0.25s ease;
    }

    .text-input:hover {
        transform:scale(1.1);
    }
    .text-input:focus {
        border-color: #ff3333;
        box-shadow: 0 0 10px rgba(255, 50, 50, 0.6);
    }

    .registration-button {
        width: 140px;
        height: 45px;
        font-family: Bahnschrift;
        font-size: 17px;
        color: white;
        background-color: #7a0000;
        border-radius: 12px;
        border: 2px solid #ff1a1a;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.6);
        transition: transform 0.25s ease, background-color 0.25s ease, box-shadow 0.25s ease;
        cursor: pointer;
    }

    .registration-button:hover {
        transform: scale(1.1);
        background-color: #b30000;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.7);
    }

    .registration-button:active {
