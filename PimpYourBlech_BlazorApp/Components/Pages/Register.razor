@page "/register";
@using System.Security.Cryptography
@using System.Text
@using Blazored.Toast.Services
@using PimpYourBlech_BlazorApp.Components.Icons
@using PimpYourBlech_BlazorApp.Services
@using PimpYourBlech_BlazorApp.Services.Images
@using PimpYourBlech_BlazorApp.Services.Toasts
@using PimpYourBlech_ClassLibrary.Exceptions
@using PimpYourBlech_ClassLibrary.Services.CustomerCommunication
@using PimpYourBlech_ClassLibrary.Services.CustomerCommunication.Implementation
@using PimpYourBlech_ClassLibrary.Services.Customers
@inject ICustomerService CustomerService
@inject NavigationManager Nav
@inject IImageService ImageService
@inject IToastExecutor Executor
@inject ILogger<Register> Logger
@attribute [Routes.AllowAnonymous]

<PageTitle>Registration</PageTitle>
<div class="menu-container">
    <h3 class="headline-admin">Registrierung</h3>
    <div class="user-image"
         style="cursor: pointer"
         @onclick="SelectAvatar">
        <img src="@SelectedAvatar" class="user-photo" />
    </div>
    <h7 class="headline-admin">Klicke auf den Kopf, um einen Avatar auszuwählen</h7>

    @if (ShowAvatarMenu)
    {
        <div class="avatar-dropdown">
            <img src=@Avatar1 class="avatar-option"
                 @onclick="() => ChooseAvatar(Avatar1)" />

            <img src=@Avatar2 class="avatar-option"
                 @onclick="() => ChooseAvatar(Avatar2)" />

            <img src=@Avatar3 class="avatar-option"
                 @onclick="() => ChooseAvatar(Avatar3)" />
        </div>
    }

    @*Benachrichtigungen bei Fehlern oder als Bestätigung (Wird aktiviert falls die message gesetzt wird*@
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger">@ErrorMessage</div>
    }
    @if (!string.IsNullOrEmpty(SuccessMessage))
    {
        <div class="alert alert-success">@SuccessMessage</div>
    }


    @*Alle Eingabefelder (Daten werden mit @bind in Variable gespeichert zum Weiterverwenden)*@
    <input class="text-inputPYB"
           placeholder="Username"
           @bind="username"/>

    <input class="text-inputPYB"
           placeholder="Vorname"
           @bind="firstName"/>

    <input class="text-inputPYB"
           placeholder="Nachname"
           @bind="lastName"/>

    
    <input class="text-inputPYB"
           placeholder="Telefonnummer"
           @bind="phone"/>

    <input class="text-inputPYB"
           placeholder="Email-Adresse"
           @bind="email"/>

    <input class="text-inputPYB"
           placeholder="Email-Adresse bestätigen"
           @bind="emailConfirm"/>

    <input class="text-inputPYB"
           type="password"
           placeholder="Passwort"
           @bind="password"/>

    <input class="text-inputPYB"
           type="password"
           placeholder="Passwort bestätigen"
           @bind="passwordConfirm"/>

    <button class="buttons" @onclick="RegisterCustomer">Registrieren</button>
    <button class="buttons" @onclick="Cancel">Abbrechen</button>
</div>

@code {

    // Felder für die benötigten Werte eines Customers
    private string firstName = "";
    private string lastName = "";
    private string phone = "";
    private string email = "";
    private string emailConfirm = "";
    private string username = "";
    private string password = "";
    private string passwordConfirm = "";

    // Felder für die Fehler-/Erfolgsmeldungen
    private string ErrorMessage = "";
    private string SuccessMessage = "";
    private bool isRegistering;

    // Registrieren eines Kunden
    private async Task RegisterCustomer()
    {
        if (isRegistering) return;
        isRegistering = true;
        ErrorMessage = "";
        SuccessMessage = "";

        Logger.LogInformation(
            "Registration attempt for username {Username}",
            username
        );
        var loginfo = "Registration failed for username " + username;
        var succeded = await Executor.RunAsync(() => CustomerService.RegisterCustomerAsync(firstName, lastName, username, password, passwordConfirm, phone, email, emailConfirm, SelectedAvatar)
            , successMessage: "Registrierung erfolgreich. Bitte melde dich an.", logError: loginfo);
        if (succeded)
        {
            Logger.LogInformation(
                "Registration successful for username {Username}",
                username
            );
        }

        isRegistering = false;
        @* try
        {
            await AdminService.RegisterCustomerAsync(firstName, lastName, username, password, passwordConfirm, phone, email, emailConfirm, SelectedAvatar);
            
            Logger.LogInformation(
                "Registration successful for username {Username}",
                username
            );
            
            SuccessMessage = "Registrierung erfolgreich. Bitte melde dich an.";
        }
        catch (Exception ex) when (
            ex is WrongInputException ||  
            ex is WrongPasswordException ||
            ex is UsernameNotAvailableException
        )
        {
            Logger.LogWarning(
                ex,
              "  Registration failed for username {Username}",
                username
            );
            
            ErrorMessage = ex.Message;
        }
        finally
        {
            isRegistering = false;
        }*@
    }

    // Kehrt zurück zum Start - Screen
    private void Cancel()
    {
        Nav.NavigateTo("/");
    }

    private List<String> Images = new List<string>();

    private string Avatar1;
    private string Avatar2;
    private string Avatar3;


    protected override void OnInitialized()
    {
        Images = ImageService.GetCustomerImageUrl();
        Avatar1 = Images[0];
        Avatar2 = Images[1];
        Avatar3 = Images[2];
    }

    private bool ShowAvatarMenu = false;
    private string SelectedAvatar = "user.png";

    private void SelectAvatar()
    {
        ShowAvatarMenu = !ShowAvatarMenu;
    }

    private void ChooseAvatar(string avatar)
    {
        SelectedAvatar = avatar;
        ShowAvatarMenu = false;
        StateHasChanged();
    }

}
<style>

    .avatar-dropdown {
        margin-top: 10px;
        padding: 10px;
        background: rgba(0,0,0,0.45);
        backdrop-filter: blur(6px);
        border-radius: 12px;
        border: 1px solid rgba(255, 0, 0, 0.4);

        display: flex;
        gap: 12px;
        justify-content: center;

        animation: fadeIn 0.2s ease-out;
    }

    .avatar-option {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        cursor: pointer;
        transition: 0.2s ease;
        border: 2px solid transparent;
    }

    .avatar-option:hover {
        transform: scale(1.1);
        border-color: #ff3333;
        box-shadow: 0 4px 10px rgba(0,0,0,0.5);
    }
    
</style>
