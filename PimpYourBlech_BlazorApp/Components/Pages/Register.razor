@page "/register";
@using System.Security.Cryptography
@using System.Text
@using PimpYourBlech_BlazorApp.Components.Icons
@using PimpYourBlech_ClassLibrary.Exceptions
@using PimpYourBlech_ClassLibrary.Services.Admin
@using PimpYourBlech_ClassLibrary.Services.CustomerCommunication
@using PimpYourBlech_ClassLibrary.Services.CustomerCommunication.Implementation
@inject IAdminService AdminService
@inject NavigationManager Nav

<PageTitle>Registration</PageTitle>

<div class="registration-container">
    <h3 class="headline">Registrierung</h3>
    <img src="benutzer.png" class="user-image" @onclick="SelectAvatar">
    @if (ShowAvatarMenu)
    {
        <div class="avatar-dropdown">
            <img src="Car1.png" class="avatar-option"/>
            <img src="Car2.png" class="avatar-option"/>
            <img src="Car3.png" class="avatar-option" />
        </div>
    }


    @*Benachrichtigungen bei Fehlern oder als Bestätigung (Wird aktiviert falls die message gesetzt wird*@
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger">@ErrorMessage</div>
    }
    @if (!string.IsNullOrEmpty(SuccessMessage))
    {
        <div class="alert alert-success">@SuccessMessage</div>
    }


    @*Alle Eingabefelder (Daten werden mit @bind in Variable gespeichert zum Weiterverwenden)*@
    <input class="text-input"
           placeholder="Username"
           @bind="username"/>

    <input class="text-input"
           placeholder="Vorname"
           @bind="firstName"/>

    <input class="text-input"
           placeholder="Nachname"
           @bind="lastName"/>

    
    <input class="text-input"
           placeholder="Telefonnummer"
           @bind="phone"/>

    <input class="text-input"
           placeholder="Email-Adresse"
           @bind="email"/>

    <input class="text-input"
           placeholder="Email-Adresse bestätigen"
           @bind="emailConfirm"/>

    <input class="text-input"
           type="password"
           placeholder="Passwort"
           @bind="password"/>

    <input class="text-input"
           type="password"
           placeholder="Passwort bestätigen"
           @bind="passwordConfirm"/>

    <button class="buttons" @onclick="RegisterCustomer">Registrieren</button>
    <button class="buttons" @onclick="Cancel">Abbrechen</button>
</div>



@code {
    // Felder für die benötigten Werte eines Customers
    private string firstName = "";
    private string lastName = "";
    private string phone = "";
    private string email = "";
    private string emailConfirm = "";
    private string username = "";
    private string password = "";
    private string passwordConfirm = "";

    // Felder für die Fehler-/Erfolgsmeldungen
    private string ErrorMessage = "";
    private string SuccessMessage = "";

    // Registrieren eines Kunden
    private void RegisterCustomer()
    {
        // Email wird auf Korrektheit geprüft
        try
        {
            EmailService.IsValid(email);
            EmailService.ConfirmRegistrationChecker(email, emailConfirm);
        }
        catch (WrongInputException ex)
        {
            ErrorMessage = ex.Message;
            return;
        }

        // Prüfung ob der Username verfügbar ist
        try
        {
            AdminService.isUsernameAvailable(username);
        }
        catch (UsernameNotAvailableException ex)
        {
            ErrorMessage = ex.Message;
            return;
        }
        
        //Prüfung ob das Passwort dasselbe ist
        try
        {
            PasswordChecker(password, passwordConfirm);
        }
        catch (WrongPasswordException wp)
        {
            ErrorMessage = wp.Message;
            return;
        }

        

        // Hash - Code des Passworts wird generiert
        var hash = Convert.ToBase64String(
            SHA256.HashData(Encoding.UTF8.GetBytes(password ?? ""))
        );

        // Mittels des AdminService wird der Benutzer registriert und die Erfolgsmeldung gesetzt + angezeigt
        AdminService.Register(firstName, lastName, username, hash, phone, email);
        SuccessMessage = "Registrierung erfolgreich. Bitte melde dich an.";

       
    }
    private void PasswordChecker(string pw, string confirm)
    {
        if (pw != confirm)
            throw new WrongPasswordException("Die Passwörter stimmen nicht überein.");
    }
    // Kehrt zurück zum Start - Screen
    private void Cancel()
    {
        Nav.NavigateTo("/");
    }

    private bool ShowAvatarMenu = false;
    private string SelectedAvatar = "benutzer.png";

    private void SelectAvatar()
    {
        ShowAvatarMenu = !ShowAvatarMenu;
    }

    private void ChooseAvatar(string avatar)
    {
        SelectedAvatar = avatar;
        ShowAvatarMenu = false;
    }

}

<style>
    .headline {
        font-family: Bahnschrift;
        color: white;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.7);
    }

    .registration-container {
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 12px;
        width: 55%;
        height: 100%;
        padding: 25px;
        background: rgba(0, 0, 0, 0.25);
        backdrop-filter: blur(8px); 
        -webkit-backdrop-filter: blur(8px);
        border-radius: 18px;
        border: 1px solid rgba(255, 0, 0, 0.25);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.6);
    }

    .user-image {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 2px solid rgba(255, 0, 0, 0.5);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.8);
        cursor: pointer;
    }

    .text-input {
        width: 240px;
        height: 38px;
        padding: 6px;
        font-family: Bahnschrift;
        text-align: center;
        background-color: rgba(20, 0, 0, 0.65); 
        color: white;
        border-radius: 10px;
        border: 2px solid rgba(255, 0, 0, 0.6);
        outline: none;
        transition: 0.25s ease;
    }

    .text-input:hover {
        transform:scale(1.1);
    }
    .text-input:focus {
        border-color: #ff3333;
        box-shadow: 0 0 10px rgba(255, 50, 50, 0.6);
    }

    .buttons {
        width: 140px;
        height: 45px;
        font-family: Bahnschrift;
        font-size: 17px;
        color: white;
        background-color: #7a0000;
        border-radius: 12px;
        border: 2px solid #ff1a1a;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.6);
        transition: transform 0.25s ease, background-color 0.25s ease, box-shadow 0.25s ease;
        cursor: pointer;
    }

    .buttons:hover {
        transform: scale(1.1);
        background-color: #b30000;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.7);
    }

    .buttons:active {
        transform: scale(1.2);
    }

    .avatar-dropdown {
        margin-top: 10px;
        padding: 10px;
        background: rgba(0,0,0,0.45);
        backdrop-filter: blur(6px);
        border-radius: 12px;
        border: 1px solid rgba(255, 0, 0, 0.4);

        display: flex;
        gap: 12px;
        justify-content: center;

        animation: fadeIn 0.2s ease-out;
    }

    .avatar-option {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        cursor: pointer;
        transition: 0.2s ease;
        border: 2px solid transparent;
    }

    .avatar-option:hover {
        transform: scale(1.1);
        border-color: #ff3333;
        box-shadow: 0 4px 10px rgba(0,0,0,0.5);
    }


</style>
