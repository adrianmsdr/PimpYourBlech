@code {
    // Felder für die benötigten Werte eines Customers
    private string firstName = "";
    private string lastName = "";
    private string phone = "";
    private string email = "";
    private string emailConfirm = "";
    private string username = "";
    private string password = "";
    private string passwordConfirm = "";

    // Felder für die Fehler-/Erfolgsmeldungen
    private string ErrorMessage = "";
    private string SuccessMessage = "";

    // Registrieren eines Kunden
    private void RegisterCustomer()
    {
        // Email wird auf Korrektheit geprüft
        try
        {
            EmailService.IsValid(email);
            EmailService.ConfirmRegistrationChecker(email, emailConfirm);
        }
        catch (WrongInputException ex)
        {
            ErrorMessage = ex.Message;
            return;
        }

        // Prüfung ob der Username verfügbar ist
        try
        {
            AdminService.isUsernameAvailable(username);
        }
        catch (UsernameNotAvailableException ex)
        {
            ErrorMessage = ex.Message;
            return;
        }
        
        //Prüfung ob das Passwort dasselbe ist
        try
        {
            PasswordChecker(password, passwordConfirm);
        }
        catch (WrongPasswordException wp)
        {
            ErrorMessage = wp.Message;
            return;
        }

        

        // Hash - Code des Passworts wird generiert
        var hash = Convert.ToBase64String(
            SHA256.HashData(Encoding.UTF8.GetBytes(password ?? ""))
        );

        // Mittels des AdminService wird der Benutzer registriert und die Erfolgsmeldung gesetzt + angezeigt
        AdminService.Register(firstName, lastName, username, hash, phone, email, SelectedAvatar);
        SuccessMessage = "Registrierung erfolgreich. Bitte melde dich an.";

       
    }
    private void PasswordChecker(string pw, string confirm)
    {
        if (pw != confirm)
            throw new WrongPasswordException("Die Passwörter stimmen nicht überein.");
    }
    // Kehrt zurück zum Start - Screen
    private void Cancel()
    {
        Nav.NavigateTo("/");
    }

    private List<String> Images = new List<string>();

    private string Avatar1;
    private string Avatar2;
    private string Avatar3;

    private readonly IWebHostEnvironment _env;

    protected override void OnInitialized()
    {
        Images = ImageService.GetCustomerImageUrl();
        Avatar1 = Images[0];
        Avatar2 = Images[1];
        Avatar3 = Images[2];
    }

    private bool ShowAvatarMenu = false;
    private string SelectedAvatar = "benutzer.png";

    private void SelectAvatar()
    {
        ShowAvatarMenu = !ShowAvatarMenu;
    }

    private void ChooseAvatar(string avatar)
    {
        SelectedAvatar = avatar;
        ShowAvatarMenu = false;
        StateHasChanged();
    }

}

