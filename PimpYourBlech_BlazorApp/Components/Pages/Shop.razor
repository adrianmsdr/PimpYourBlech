@page "/shop"
@rendermode InteractiveServer
@using PimpYourBlech_ClassLibrary.Entities

@using PimpYourBlech_ClassLibrary.Services.Shop

@inject NavigationManager Nav

@inject IShopService ShopService

<h3>Ersatzteile - Shop</h3>

@*
Machen wir noch schön Bleibt nicht so aber im Prinzip holt der sich alle Produkte erstmal und zeigt sie mit
ausgewählten infos + bild in so nem Kästchen wär noch schön
- sollte man später auch anklicken können + warenkorb und alles drum und dran
*@

<div class="input-group mb-3">
    <input class="form-control"
           placeholder="Nach Artikelnummer, Name, Hersteller suchen..."
           @bind="searchText" />

    <button class="btn btn-primary" @onclick="ApplySearch">
        Suchen
    </button>
    
</div>
<div class="d-flex align-items-center mb-3 gap-3">

    @*Filter: Kategorie*@
    <div class="d-flex align-items-center">
        <label class="me-2 mb-0">Kategorie:</label>
        <select class="form-select" style="width: 200px"
                @bind="selectedCategory">
            <option value="All">Alle</option>
            <option value="Engine">Motor</option>
            <option value="Rim">Felge</option>
            <option value="Lights">Lichtanlage</option>
            <!-- weitere Kategorien später -->
        </select>
    </div>
    

    @*Sortierung*@
    <div class="d-flex align-items-center ms-auto">
        <label class="me-2 mb-0">Sortieren nach:</label>
        <select class="form-select" style="width: 220px"
                @bind="selectedSortOption">
            <option value="NameAscending">Name (A–Z)</option>
            <option value="NameDescending">Name (Z–A)</option>
            <option value="PriceAscending">Preis (aufsteigend)</option>
            <option value="PriceDescending">Preis (absteigend)</option>
        </select>
    </div>
</div>

@if (products == null)
{
    <p>Lade Produkte...</p>
}
else if (!products.Any())
{
    <p>Keine Produkte vorhanden.</p>
}
else
{
    <div class="product-grid">
        @foreach (var product in products)
        {
            <div class="product-card">
                <img src="@GetImage(product)" alt="@product.Name" class="product-image" />
                <div class="product-info">
                    <h4>@product.Name</h4>
                    <p>@product.Brand</p>
                    <p class="product-price">@product.Price.ToString("C")</p>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Product> products;
    private string selectedCategory = "Alle";
    private string selectedSortOption = "NameAufsteigend";
    private string searchText = string.Empty;
    // Damit wird die methode automatisch aufgerufen beim laden der seite (also alle produkte geholt)
    protected override void OnInitialized()
    {
        LoadProducts();
    }
    //  |
    //  v
    public void LoadProducts()
    {
        products = ShopService.GetProducts();
    }
    
    

    private void ApplySearch()
    {
       products = ShopService.SearchProducts(searchText);
        
    }

    // Hier soll er sich später das Bild holen
    private string GetImage(Product p)
    {
        return string.IsNullOrWhiteSpace(p.ImageUrl)
            ? "/images/placeholder.png"
            : p.ImageUrl;
    }

    // Führt zum Hauptmenü
    private void Cancel()
    {
        Nav.NavigateTo("/mainMenu");
    }
}