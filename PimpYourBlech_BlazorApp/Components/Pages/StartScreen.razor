@page "/"
@using System.Text.Json
@using PimpYourBlech_BlazorApp.Components.Icons
@inject NavigationManager Nav
@attribute [Routes.AllowAnonymous]


<PageTitle>PimpYourBlech</PageTitle>


<div class="hero-bleed">
    <div class="header-wrapper">
        <img src="HeaderMainMenu.png" class="header-image">
    </div>
</div>


<div class="home-section">
    <div class="main-row">
        <div class="our-partners-box partner-card">
            <img src="unsere-partner.png" class="our-partners">
        </div>

        <div class="menu-container">
            <button class="buttons car-button" @onclick="StartProgramm">
                <span class="car-icon">
                    <DrivingCarIcon />
                </span>
                <span class="button-text">
                    Zeit zu pimpen!
                </span>
            </button>

            <div class="button-column">
               
                <img class="video" src="/PYB-Video.webp" alt="" />
            </div>
        </div>
        
        <div class="partner-card">
            <h3 class="partner-title">Unsere Kooperationspartner</h3>

            <div class="partner-logo-wrapper">
                <img src="@currentImage" class="partner-logo" />
            </div>
            <button class="nextimagebutton" @onclick="NextImage">Neues Bild</button>
        </div>

        </div>
    </div>


@code
{
    // Wichtig: Wikipedia REST API blockt gerne Requests ohne User-Agent -> sonst immer Fallback
    private static readonly HttpClient http = CreateHttp();

    private bool isLoading = true;
    private string factText = "";
    private string factUrl = "";
    private int yearsAgo;

    private static HttpClient CreateHttp()
    {
        var c = new HttpClient();
        c.DefaultRequestHeaders.UserAgent.ParseAdd("PimpYourBlech/1.0 (Blazor; localhost)");
        c.DefaultRequestHeaders.Accept.ParseAdd("application/json");
        return c;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadOnThisDay();
    }

    private async Task LoadOnThisDay()
    {
        isLoading = true;
        factText = "Lade…";
        factUrl = "";
        yearsAgo = 0;
        StateHasChanged();

        var today = DateTime.Today;
        var url = $"https://de.wikipedia.org/api/rest_v1/feed/onthisday/events/{today:MM}/{today:dd}";

        try
        {
            using var resp = await http.GetAsync(url);
            var body = await resp.Content.ReadAsStringAsync();

            if (!resp.IsSuccessStatusCode)
            {
                factText = $"Wikipedia API Fehler: {(int)resp.StatusCode} {resp.ReasonPhrase}";
                factUrl = "";
                yearsAgo = 0;
                isLoading = false;
                return;
            }

            using var doc = JsonDocument.Parse(body);
            var events = doc.RootElement.GetProperty("events");

            var count = events.GetArrayLength();
            if (count == 0)
            {
                factText = "Keine Ereignisse für heute gefunden.";
                factUrl = "";
                yearsAgo = 0;
                isLoading = false;
                return;
            }

            // Random Event picken
            var idx = Random.Shared.Next(count);
            var ev = events[idx];

            var text = ev.GetProperty("text").GetString() ?? "";
            var year = ev.GetProperty("year").GetInt32();

            yearsAgo = today.Year - year;
            factText = $"{year}: {text}";

            // Optional Link (wenn vorhanden)
            if (ev.TryGetProperty("pages", out var pages) && pages.GetArrayLength() > 0)
            {
                var p0 = pages[0];
                if (p0.TryGetProperty("content_urls", out var cu) &&
                    cu.TryGetProperty("desktop", out var desk) &&
                    desk.TryGetProperty("page", out var page))
                {
                    factUrl = page.GetString() ?? "";
                }
            }

            isLoading = false;
        }
        catch (Exception ex)
        {
            yearsAgo = 0;
            factText = $"Exception: {ex.GetType().Name} – {ex.Message}";
            factUrl = "";
            isLoading = false;
        }
    }
    
    private string[] images =
    {
        "elitegaertner_werbung.png",
        "kardei_werbung.jpeg",
        "ralfschuhmacherad.png",
        "schanzenfest_werbung.jpeg"
    };

    private int currentIndex = 0;
    private string currentImage => images[currentIndex];

    private void NextImage()
    {
        currentIndex = (currentIndex + 1) % images.Length;
    }
    
    public void StartProgramm()
    {
        Nav.NavigateTo("/startMenu");
    }
    
}
