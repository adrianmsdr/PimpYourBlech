@page "/"
@using PimpYourBlech_BlazorApp.Components.Icons
@inject NavigationManager Nav


<PageTitle>PimpYourBlech</PageTitle>

<div class="content">
    <div class="header-wrapper">
        <img src="HeaderMainMenu.png" class="header-image">
    </div>

    <div class="main-row">
        <div class="our-partners-box">
            <img src="unsere-partner.png" class="our-partners">
        </div>

        <div class="menu-container">
            <button class="buttons car-button" @onclick="StartProgramm">
                <span class="car-icon">
                    <DrivingCarIcon />
                </span>
                <span class="button-text">
                    Zeit zu pimpen!
                </span>
            </button>

            <div class="button-column">
                <video
                    class="video"
                    autoplay
                    muted
                    loop
                    playsinline
                    preload="auto">
                    <source src="PYB-Video.mp4" type="video/mp4"/>
                    Dein Browser unterstützt kein HTML5-Video.
                </video>
            </div>
        </div>
    </div>
</div>


@code
{
    public void StartProgramm()
    {
        Nav.NavigateTo("/startMenu");
    }
}
<style>
    
    .main-row {
        margin-top: 30px;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        gap: 24px;
    }

    .header-wrapper {
        width: 100%;
        overflow: hidden;
        background: rgba(0, 0, 0, 0.25);
        backdrop-filter: blur(8px);
        border-radius: 18px;
        border: 1px solid rgba(255, 0, 0, 0.25);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.6);
    }

    .header-image {
        width: 100%;
        max-height: 320px;
        display: block;
        object-fit: cover;
        object-position: center 12%;
    }
    
    .menu-container {
        margin: 30px auto 0 auto;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 16px;
        width: 55%;
        padding: 25px;
        background: rgba(0, 0, 0, 0.25);
        backdrop-filter: blur(8px);
        border-radius: 18px;
        border: 1px solid rgba(255, 0, 0, 0.25);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.6);
        margin-bottom: 8px;
        margin-left: -14px;
    }
    
    .button-column {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 14px;
        align-items: center;
    }
    
    .video {
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        border-radius: 22px;
        box-shadow: 0 25px 60px rgba(0, 0, 0, 0.65);
    }
    
    .buttons {
        width: 100%;
        height: 45px;
        font-family: Bahnschrift;
        font-size: 1.1rem;
        color: white;
        background-color: #7a0000;
        border-radius: 12px;
        border: 2px solid #ff1a1a;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.6);
        cursor: pointer;
        transition: transform 0.25s ease, background-color 0.25s ease;
    }

    .buttons:hover {
        transform: scale(1.05);
        background-color: #b30000;
    }

    .car-button {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        gap: 10px;
        transition: background-color 0.35s ease, box-shadow 0.35s ease;
    }
    
    .car-icon {
        position: absolute;
        left: 18px;
        opacity: 0;
        transform: scale(0.8);
        display: flex;
        align-items: center;
        transition:
            left 0.45s ease,
            transform 0.45s ease,
            opacity 0.3s ease;
    }
    
    .button-text {
        transition: opacity 0.35s ease;
    }
    
    .button-text:hover {
        opacity: 0;
    }
    
    .car-button:hover {
        background-color: #5a0000;
        box-shadow: 0 10px 22px rgba(0, 0, 0, 0.8);
    }
    
    .car-button:hover .car-icon {
        left: 50%;
        transform: translateX(-50%) scale(1);
        opacity: 1;
    }
    
    .car-button:hover .button-text {
        opacity: 0.2;
    }

    .our-partners {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }
    
    .our-partners-box {
        width: 280px;
        height: 550px;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 12px;
        overflow: hidden;
        background: rgba(0, 0, 0, 0.25);
        backdrop-filter: blur(8px);
        border-radius: 18px;
        border: 1px solid rgba(255, 0, 0, 0.25);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.6);
    }

</style>