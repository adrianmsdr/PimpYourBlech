        color: #c3c0c0;
    }

    /* Stand Highlight + WOW Effect */
    .stand-highlight {
        width: 100%;
        margin-top: 2.8rem;
        padding: 1rem 1.4rem;

        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);

        border-radius: 6px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);

        position: relative;
        overflow: hidden;
    }

    .stand-highlight::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;

        width: 100%;
        height: 2px;

        background: linear-gradient(
            90deg,
            transparent,
            darkred,
            transparent
        );

        opacity: 0.6;
        transform: translateX(-100%);
        transition: transform 0.8s ease;
    }

    .stand-highlight:hover::before {
        transform: translateX(100%);
    }

    .stand-highlight:hover {
        transform: translateY(-2px);
        transition: transform 0.3s ease;
    }
</style>
