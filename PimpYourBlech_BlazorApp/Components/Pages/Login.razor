@page "/login"

@using System.Diagnostics.Metrics
@using System.Security.Cryptography
@using System.Text
@using PimpYourBlech_ClassLibrary.Services.Admin
@using PimpYourBlech_ClassLibrary.Session
@using PimpYourBlech_ClassLibrary.Session.State
@inject IAdminService AdminService
@inject IUserSession UserSession
@inject ILogger<Login> Logger
@inject NavigationManager Nav
@attribute [Routes.AllowAnonymous]

<PageTitle>LogIn</PageTitle>

@if (isLoggingIn)
{
    <div class="upload-overlay">
        <div class="upload-spinner">
            Du wirst eingeloggt ...
        </div>
    </div>
}

@*EditForm um Enter drücken zum Anmelden zu ermöglichen*@
<EditForm Model="@this">
    
    <div class="menu-container">
        <h2 class="headline-admin">Anmelden</h2>
        <img src="benutzer.png" class="user-image">
        
        @*Benachrichtigungen bei Fehlern oder als Bestätigung (Wird aktiviert falls die message gesetzt wird*@
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger">@ErrorMessage</div>
        }
        @if (!string.IsNullOrEmpty(DebugInfo))
        {
            <p style="color: orange;">DEBUG: @DebugInfo</p>
        }
        
        @*Eingabefelder für Username und Passwort*@
        <div class="mb-3">
            <input class="text-inputPYB"
                   placeholder="Username"
                   @bind="username"/>
        </div>

        <div class="mb-3">
            <input class="text-inputPYB"
                   type="password"
                   placeholder="Passwort"
                   @bind="password"/>
        </div>
        <p class="no-account-yet">Noch kein Account? 
            <span class="registrate-now" @onclick="NavigateToRegister">Jetzt registrieren</span></p>

        @*Buttons um sich anzumelden oder um zum Start - Screen zurückzukehren*@
        <div class="d-flex gap-2">
            <button class="buttons" @onclick="LoginCustomer">Anmelden</button>
            <button class="buttons" @onclick="Cancel">Abbrechen</button>
        </div>
    </div>
</EditForm>

@code {
    // Felder für die benötigten Werte und Fehlermeldungen etc.
    private string DebugInfo = "";
    private string username = "";
    private string password = "";
    private string ErrorMessage = "";
    private bool isLoggingIn;

    private async Task LoginCustomer()
    {
        if (isLoggingIn) return;
        
        Logger.LogInformation(
            "Login attempt for username {Username}",
            username
        );
        
        
        isLoggingIn = true;
        StateHasChanged();

        // AdminService führt den LoginCheck mit den Userdaten aus
        try
        {
            var c = await AdminService.CustomerLoginAsync(username, password); 
            UserSession.LogIn(c);
            LoginState.CurrentUserId = c.Id;
            
            Logger.LogInformation(
                "Login successful for user {UserId}",
                c.Id
            );
           
            Nav.NavigateTo("/mainMenu");
        }

        catch (Exception ex)
        {
            
            Logger.LogWarning(
                ex,
                "Login failed for username {Username}",
                username
            );
            // Bei Fehler: Fehlermeldung wird gesetzt
            ErrorMessage = ex.Message;
        }
        finally
        {
            isLoggingIn = false;
            StateHasChanged();
        }
    }

    // Führt zum Start - Screen
    private void Cancel()
    {
        Nav.NavigateTo("/");
    }

    private void NavigateToRegister()
    {
        Nav.NavigateTo("/register");
    }
}

<style>
    
    .user-image {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 2px solid rgba(255, 0, 0, 0.5);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.8);
    }
    
    
    .no-account-yet {
        color: white;
        font-family: Bahnschrift;
    }
    
    .registrate-now {
        color: darkslateblue;
        font-family: Bahnschrift;
        font-weight: bold;
    }
    .registrate-now:hover {
        text-decoration: underline;
        color: #ba3a25;
        cursor: pointer;
    }
</style>
