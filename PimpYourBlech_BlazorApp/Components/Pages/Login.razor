@page "/login"
@rendermode InteractiveServer

@using System.Security.Cryptography
@using System.Text
@using PimpYourBlech_ClassLibrary.Services.Admin
@using PimpYourBlech_ClassLibrary.Session
@inject IAdminService AdminService
@inject IUserSession UserSession
@inject NavigationManager Nav

<PageTitle>LogIn</PageTitle>

@*Benachrichtigungen bei Fehlern oder als Bestätigung (Wird aktiviert falls die message gesetzt wird*@
@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}
@if (!string.IsNullOrEmpty(DebugInfo))
{
    <p style="color: orange;">DEBUG: @DebugInfo</p>
}


@*EditForm um Enter drücken zum Anmelden zu ermöglichen*@
<EditForm Model="@this">
    
    <div class="registration-container">
        <h2 class="headline">Anmelden</h2>
        <img src="benutzer.png" class="user-image">
        @*Eingabefelder für Username und Passwort*@
        <div class="mb-3">
            <input class="text-input"
                   placeholder="Username"
                   @bind="username"/>
        </div>

        <div class="mb-3">
            <input class="text-input"
                   type="password"
                   placeholder="Passwort"
                   @bind="password"/>
        </div>
        <p class="no-account-yet">Noch kein Account? 
            <span class="registrate-now" @onclick="NavigateToRegister">Jetzt registrieren</span></p>

        @*Buttons um sich anzumelden oder um zum Start - Screen zurückzukehren*@
        <div class="d-flex gap-2">
            <button class="buttons" @onclick="LoginCustomer">Anmelden</button>
            <button class="buttons" @onclick="Cancel">Abbrechen</button>
        </div>
    </div>
</EditForm>

@code {
    // Felder für die benötigten Werte und Fehlermeldungen etc.
    private string DebugInfo = "";
    private string username = "";
    private string password = "";
    private string ErrorMessage = "";

    private void LoginCustomer()
    {
        // Passwort wird in Hashcode konvertiert für DB - Abgleich
        var hash = Convert.ToBase64String(
            SHA256.HashData(Encoding.UTF8.GetBytes(password ?? ""))
        );

        // AdminService führt den LoginCheck mit den Userdaten aus
        if (AdminService.LoginAccepted(username, hash))
        {
            // Bei Erfolg: User wird als eingeloggt gesetzt + Hauptmenü erscheint
            var c = AdminService.GetCustomer(username, hash);
            UserSession.LogIn(c);
            Nav.NavigateTo("/mainMenu", forceLoad: true); // entspricht Screens.MainMenu
        }
        else
        {
            // Bei Fehler: Fehlermeldung wird gesetzt
            ErrorMessage = "Anmeldung fehlgeschlagen.";
        }
    }

    // Führt zum Start - Screen
    private void Cancel()
    {
        Nav.NavigateTo("/");
    }

    private void NavigateToRegister()
    {
        Nav.NavigateTo("/register");
    }
}

<style>
    .headline {
        font-family: Bahnschrift;
        color: white;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.7);
    }

    .registration-container {
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 12px;
        width: 55%;
        height: 100%;
        padding: 25px;
        background: rgba(0, 0, 0, 0.25);
        backdrop-filter: blur(8px); 
        -webkit-backdrop-filter: blur(8px);
        border-radius: 18px;
        border: 1px solid rgba(255, 0, 0, 0.25);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.6);
    }

    .user-image {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 2px solid rgba(255, 0, 0, 0.5);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.8);
    }

    .text-input {
        width: 240px;
        height: 38px;
        padding: 6px;
        font-family: Bahnschrift;
        text-align: center;
        background-color: rgba(20, 0, 0, 0.65); 
        color: white;
        border-radius: 10px;
        border: 2px solid rgba(255, 0, 0, 0.6);
        outline: none;
        transition: 0.25s ease;
    }
    
    .text-input:hover {
        transform:scale(1.1);
    }

    .text-input:focus {
        border-color: #ff3333;
        box-shadow: 0 0 10px rgba(255, 50, 50, 0.6);
    }

    .buttons {
        width: 140px;
        height: 45px;
        font-family: Bahnschrift;
        font-size: 17px;
        color: white;
        background-color: #7a0000;
        border-radius: 12px;
        border: 2px solid #ff1a1a;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.6);
        transition: transform 0.25s ease, background-color 0.25s ease, box-shadow 0.25s ease;
        cursor: pointer;
    }

    .buttons:hover {
        transform: scale(1.1);
        background-color: #b30000;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.7);
    }

    .buttons:active {
        transform: scale(1.2);
    }
    
    .no-account-yet {
        color: white;
        font-family: Bahnschrift;
    }
    
    .registrate-now {
        color: darkslateblue;
        font-family: Bahnschrift;
        font-weight: bold;
    }
    .registrate-now:hover {
        text-decoration: underline;
        color: #ba3a25;
        cursor: pointer;
    }
</style>
