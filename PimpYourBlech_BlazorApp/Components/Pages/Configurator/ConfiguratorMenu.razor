@page "/configurator/{id:int}"
<PageTitle>Configurator</PageTitle>

@using Microsoft.AspNetCore.WebUtilities
@using PimpYourBlech_BlazorApp.Services
@using PimpYourBlech_ClassLibrary.Entities
@using PimpYourBlech_ClassLibrary.Enums
@using PimpYourBlech_ClassLibrary.Services.Configurator
@using PimpYourBlech_ClassLibrary.Session
@inject IImageService ImageService
@inject IConfiguratorService ConfiguratorService
@inject IUserSession UserSession
@inject NavigationManager Nav


@if (configuration == null)
{
    <div class="menu-container">
        <input class="text-inputPYB"
               placeholder="Konfigurationsname"
               @bind="configurationName"/>
   
        <div class="button-column">
            <button class="buttons" @onclick="StartConfiguration">Konfiguration starten</button>
            <button class="buttons" @onclick="Cancel">Abbrechen</button>
        </div>
        </div>
}
else
{
    <div class="configurator-header">
        <img src="/KonfigBanner.png" class="header" />
        </div>
    <div class="config-strip">
        <div class="config-strip-left">
            <span class="config-strip-label">Aktuelle Konfiguration:</span>
            <span class="config-strip-name">@configuration.Name</span>
        </div>
        <div class="config-strip-right">
            <span class="config-strip-price">@totalPrice €</span>
        </div>
    </div>
    <div class="row g-4t">

        <div class="col-lg-8">


            @if (frameUrls.Count > 0)
            {
                @*360°-Ansicht*@
                <div class="car-360-wrapper">
                    <img src="@frameUrls[currentFrame]"
                         alt="360°-Ansicht @Car?.Name"
                         class="car-360-image"/>

                    <div class="car-360-controls">
                        <button class="car-360-btn" @onclick="RotateLeft">⟵</button>
                        <span class="car-360-counter">
                            @(currentFrame + 1) / @frameUrls.Count
                        </span>
                        <button class="car-360-btn" @onclick="RotateRight">⟶</button>
                    </div>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(CurrentImageUrl))
            {
                <div class="car-360-wrapper">
                    <img src="@CurrentImageUrl"
                         alt="Preview"
                         class="car-360-image"/>
                </div>
            }
            else
            {
                <div class="car-360-wrapper">
                    <div class="placeholder-text">
                        Hier wird später das 3D-Modell oder ein Bild deiner Konfiguration angezeigt.
                    </div>
                </div>
            }
        </div>
        
        <div class="col-lg-4">
            <aside class="details-panel">

                
                <div class="details-panel__header">
                    <div class="selected-item__name">@Car?.Brand @Car?.Model</div>
                </div>
               
                <div class="details-stats">
                    <div class="stat">
                        <div class="stat__label">Basis</div>
                        <div class="stat__value">@Car?.Price €</div>
                    </div>
                    <div class="stat">
                        <div class="stat__label">Extras</div>
                        <div class="stat__value">@((totalPrice - (Car?.Price ?? 0)).ToString("0.00")) €</div>
                    </div>
                    <div class="stat">
                        <div class="stat__label">Produkte</div>
                        <div class="stat__value">@configuration?.Products?.Count</div>
                    </div>
                </div>

                <div class="details-section">
                    <div class="details-section__title">Ausgewählt</div>

                    @if (configuration?.Products == null || configuration.Products.Count == 0)
                    {
                        <div class="details-empty">Noch nichts gewählt.</div>
                    }
                    else
                    {
                        <div class="selected-grid">
                            @foreach (var p in configuration.Products)
                            {
                                <div class="selected-item">
                                    <div class="selected-item__text">
                                        <div class="selected-item__name">@p.Name</div>
                                        <div class="selected-item__price">@p.Price €</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="details-total">
                    <div class="details-total__label">Gesamt</div>
                    <div class="details-total__value">@totalPrice €</div>
                </div>

            </aside>
        </div>
    </div>
    <div class="config-strip">Farbe wählen:</div>
    @if (availableColors.Count == 0)
    {
        <div class="col-4">
            <div class="combo-card-admin configurator-card">
                <p>Keine Farben verfügbar.</p>
            </div>
        </div>
    }else{
        
        <div class="row">
            @foreach (var c in availableColors)
            {var isSelected = configuration?.Products?.Any(p => p.ProductId == c.ProductId) == true;
                <div class="col-4">
                    <div class="combo-card-admin configurator-card glow-red @(isSelected ? "selected" : "")"
                         role="button"
                         tabindex="0"
                         @onclick="() => SelectColor(c.ProductId)">

                        <div class="card-media-color">
                            <img class="product-img"
                                 src="@ImageService.GetProductImageUrl(c.ProductId)"
                                 alt="@c.Name"/>
                        </div>
                        <div class="selected-item">
                            <div class="selected-itemtext">
                                <div class="selected-itemname">@c.ColorDetail.DisplayName</div>
                                <div class="selected-item__price">@c.Price</div>
                            </div>


                        </div>
                    </div>
                </div>
            }
        </div>
    }
    <div class="config-strip">Motor wählen:</div>

   

    @if (availableEngines.Count == 0)
    {
      <div class="col-4">
            <div class="combo-card-admin configurator-card">
                <p>Keine Produkte verfügbar.</p>
            </div>
        </div>
    }
    else
    {
        
        <div class="row">
            @foreach (var product in availableEngines)
            {var isSelected = configuration?.Products?.Any(p => p.ProductId == product.ProductId) == true;
                <div class="col-4">
                    <div class="combo-card-admin configurator-card @(isSelected ? "selected" : "")"
                         role="button"
                         tabindex="0"
                         @onclick="() => HandleProduct(product)">

                        <div class="card-media">
                            <img class="product-img"
                                 src="@ImageService.GetProductImageUrl(product.ProductId)"
                                 alt="@product.Name"/>
                        </div>
                        <div class="selected-item">
                            <div class="selected-item__text">
                                <div class="selected-item__name">@product.Name</div>
                                <div class="selected-item__price">@product.Price</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="config-strip">Felgen wählen:</div>

    @if (availableRims.Count == 0)
    {
         <div class="col-4">
            <div class="combo-card-admin configurator-card">
                <p>Keine Produkte verfügbar.</p>
            </div>
        </div>
    }
    else
    {
        
        <div class="row">
            @foreach (var product in availableRims)
            {var isSelected = configuration?.Products?.Any(p => p.ProductId == product.ProductId) == true;
                <div class="col-4">
                    <div class="combo-card-admin configurator-card @(isSelected ? "selected" : "")"
                         role="button"
                         tabindex="0"
                         @onclick="() => HandleProduct(product)">

                        <div class="card-media">
                            <img class="product-img"
                                 src="@ImageService.GetProductImageUrl(product.ProductId)"
                                 alt="@product.Name"/>
                        </div>
                        <div class="selected-item">
                            <div class="selected-item__text">
                                <div class="selected-item__name">@product.Name</div>
                                <div class="selected-item__price">@product.Price</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    <div class="button-column">
    <button class="buttons" @onclick="SaveConfiguration">Speichern</button>
    <button class="buttons" @onclick="DeleteConfiguration">Löschen</button>
    <button class="buttons" @onclick="GoToOrderConfiguration">Anfragen</button>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    public Car Car { get; set; }

    private string name = null;
    private string configurationName;
    private string? CurrentImageUrl;

    // 360°-Frames
    private List<string> frameUrls = new();
    private int currentFrame = 0;

    private List<Product> availableColors = new();
    private List<Product> availableEngines = new();
    private List<Product> availableRims = new();
    private List<Product> availableLights = new();

    private Configuration? configuration;
    private double totalPrice;

    private int selectedColorId = 0;
    private int selectedRimId = 0;

    private void SelectColor(int colorId)
    {
        if (configuration == null) return;

        selectedColorId = colorId;

        ConfiguratorService.AddProduct(configuration, ConfiguratorService.GetProductById(selectedColorId));
        LoadFrames();
        UpdatePrice();
    }

    protected override async Task OnInitializedAsync()
    {
        // 1) Auto laden (einmal)
        Car = ConfiguratorService.GetCarById(Id);
        if (Car == null) return;

        // 2) Farben laden
        availableColors = ConfiguratorService.GetAvailableColors(Id) ?? new List<Product>();

        // 3) Produkte laden
        availableEngines = ConfiguratorService.GetAvailableEngines(Id) ?? new List<Product>();
        availableRims = ConfiguratorService.GetAvailableRims(Id) ?? new List<Product>();


        // Default Farbe + Felge setzen (damit sofort 360° geht)
        if (availableColors.Count > 0)
            selectedColorId = availableColors[0].ProductId;

        if (availableRims.Count > 0)
            selectedRimId = availableRims[0].ProductId;

        // Frames laden über neue Kombi-Logik
        LoadFrames();


        // 4) Optional: configId aus QueryString laden
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var qs = QueryHelpers.ParseQuery(uri.Query);

        if (qs.TryGetValue("configId", out var s) && int.TryParse(s, out var configId))
        {
            configuration = ConfiguratorService.GetConfigurationById(configId);
            name = configuration?.Name;
        }

        // 5) Preis einmal am Ende
        UpdatePrice();
    }


    private void RotateLeft()
    {
        if (frameUrls.Count == 0) return;
        currentFrame = (currentFrame - 1 + frameUrls.Count) % frameUrls.Count;
    }

    private void RotateRight()
    {
        if (frameUrls.Count == 0) return;
        currentFrame = (currentFrame + 1) % frameUrls.Count;
    }

    private void HandleProduct(Product product)
    {
        if (configuration == null) return;


        ConfiguratorService.AddProduct(configuration, product);

        if (product.ProductType == ProductType.Rim)
            selectedRimId = product.ProductId;

        if (product.ProductType == ProductType.Color)
            selectedColorId = product.ProductId;


        LoadFrames();
        UpdatePrice();
    }

    private void RemoveProduct(Product product)
    {
        if (configuration == null) return;
        configuration.Products.Remove(product);
        UpdatePrice();
    }

    private void UpdatePrice()
    {
        if (configuration == null) return;
        totalPrice = ConfiguratorService.CalculateTotalPrice(configuration);
    }

    private void StartConfiguration()
    {
        name = configurationName;
        configuration = ConfiguratorService.StartNewConfiguration(UserSession.CurrentUser, Car, name);

        // Defaultfarbe + Defaultfelge als Produkt setzen
        if (availableColors.Count > 0)
        {
            selectedColorId = availableColors[0].ProductId;
            ConfiguratorService.AddProduct(configuration, availableColors[0]);
        }

        if (availableRims.Count > 0)
        {
            selectedRimId = availableRims[0].ProductId;
            ConfiguratorService.AddProduct(configuration, availableRims[0]);
        }

        LoadFrames();
        UpdatePrice();

    }

    private void Cancel()
    {
        Nav.NavigateTo("/mainMenu");
    }

    private void DeleteConfiguration()
    {
        ConfiguratorService.DeleteConfiguration(configuration);
        Nav.NavigateTo("/mainMenu");
    }

    private void GoToOrderConfiguration()
    {
        if (configuration == null || Car == null) return;
        Nav.NavigateTo($"/configurator/{Car.Id}/order/{configuration.Id}", replace: true);

    }

    private void SaveConfiguration()
    {
        ConfiguratorService.SaveConfiguration(configuration);
    }

    private void LoadFrames()
    {
        if (Car == null) return;
        if (selectedColorId == 0 || selectedRimId == 0)
        {
            frameUrls = new List<string>();
            currentFrame = 0;
            return;
        }

        frameUrls = ImageService.Get360ImageUrls(Car.Id, selectedColorId, selectedRimId) ?? new List<string>();
        currentFrame = 0;
    }

}



<style>

/* Container für die 360°-Ansicht: zentriert, abgerundet, mit Hintergrund und "clipping" */
.car-360-wrapper {
    position: relative;               /* Referenz für absolut positionierte Controls */
    max-width: 1100px;
    margin: 0 auto;
    border-radius: 12px;
    overflow: hidden;
    background-color: #f5f5f5;
}

/* Bild in der 360°-Ansicht: responsive und sauber skaliert */
.car-360-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;}

/* Untere Control-Leiste (Pfeile + Counter) für die 360°-Ansicht */
.car-360-controls {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;                        /* direkt am unteren Rand */
    padding: 0.4rem 1rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    background: #ffffff;              /* weiße Leiste */
    box-shadow: 0 -2px 6px rgba(0,0,0,0.15);
    border-top: 1px solid #ddd;
}

/* Buttons (links/rechts) für die 360°-Rotation */
.car-360-btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background: #e0e0e0;
    font-size: 1rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
}

/* Hover-Effekt für 360°-Buttons */
.car-360-btn:hover {
    background: #cccccc;
}

/* Counter-Anzeige (Frame x / y) */
.car-360-counter {
    min-width: 70px;
    text-align: center;
    font-size: 0.9rem;
}

/* Platzhaltertext, wenn keine Frames / kein Bild verfügbar ist */
.placeholder-text {
    color: #777;
    font-size: 1.1rem;
    text-align: center;
    padding: 1rem;
}

/* Bootstrap-Spalte rechts als Flex-Container, damit die Karte die volle Höhe der linken Spalte einnehmen kann */
.col-lg-4 {
    display: flex;
    align-items: stretch;
}


/* Überschriften wie "Ausgewählte Produkte" (rot, etwas Abstand nach oben) */
.car-details-card h4 {
    margin-top: 1rem;
    color: #8b0000;
}

/* =========================
   Produktkarten (Motor/Felgen/Lichter unten)
   ========================= */

/* Produktbild in den Karten: feste Höhe, zentriert durch object-fit, neutraler Hintergrund */
.product-img {
    width: 100%;
    height: 160px;
    object-fit: contain;
    background: #f5f5f5;
}

/* Gesamte Produktkarte klickbar + weicher Übergang für Hover */
.configurator-card {
    cursor: pointer;
    transition: transform 0.08s ease, box-shadow 0.08s ease;
}

/* Hover-Effekt für Produktkarten */
.configurator-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 6px 14px rgba(0,0,0,0.12);
}

.configurator-card.selected {
    box-shadow: 0 0 0 3px rgba(255, 40, 40, 1),
    0 0 12px rgba(255, 0, 0, 0.9),
    0 0 30px rgba(255, 0, 0, 0.7),
    0 0 60px rgba(255, 0, 0, 0.45);
}

.configurator-header {
      width: 100%;
