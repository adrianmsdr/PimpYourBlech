@page "/configurator/ChooseCar"
<PageTitle>Choose your Car</PageTitle>
@using PimpYourBlech_BlazorApp.Services
@using PimpYourBlech_ClassLibrary.Entities
@using PimpYourBlech_ClassLibrary.Services.Configurator
@inject IConfiguratorService ConfiguratorService
@inject NavigationManager Nav
@inject IImageService ImageService

<h3>Fahrzeug wählen:</h3>
<table class="table table-striped table-bordered">
    <thead>
    <tr>
        <th style="width: 140px;">Bild</th>
        <th>Name</th>
        <th>Hersteller</th>
        <th>Modell</th>
        <th>Preis</th>
    </tr>
    </thead>

    <tbody>
    @foreach (var c in cars)
    {

        <tr @onclick="@(() => Nav.NavigateTo($"/configurator/{c.Id}"))"
            style="cursor: pointer;">
            <td>
                <img src="@ImageService.GetCarImageUrl(c.Id)"
                     alt="@($"{c.Brand} {c.Model}")"
                     style="width:120px; height:70px; object-fit:cover; border-radius:8px;" />
            </td>
            <td>@c.Name</td>
            <td>@c.Brand</td>
            <td>@c.Model</td>
            <td>@c.Price</td>

        </tr>
    }
    </tbody>
</table>

@code {

    private List<Car> cars = new();


    protected override void OnInitialized()
    {
        cars = ConfiguratorService.ListCars();
    }
}