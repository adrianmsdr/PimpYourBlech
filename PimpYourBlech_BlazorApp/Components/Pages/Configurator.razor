@page "/configurator"
<h3>Konfigurator</h3>

<div class="config-preview">
    @if (CurrentImageUrl is not null)
    {
        <img src="@CurrentImageUrl" alt="Preview" style="width:100%; height:100%; object-fit:contain;">
    }
    else
    { 
        <div class="placeholder-text">Hier kommt unser 3D - Modell oder ein bild vom aktuellen konfigurationszusatnd rein</div>
    }
</div>
@*
- Auto wählen
- Konfiguration eigenen Namen geben
- Möglichkeiten anzeigen das Auto zu Konfigurieren
- Preis berechnen
- zurücksetzen
- undo?
- Konfiguration speichern
- Konfiguration löschen
- evtl. Direkt mit anderen vergleich
- Konfiguration umbenennen
*@
@code {
    string CurrentImageUrl = null;
}

<style>
    .config-preview {
        width: 1000px;
        height: 500px;
        border: 2px dashed #aaa;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #f5f5f5;
    }

    .placeholder-text {
        color: #777;
        font-size: 1.2rem;
    }
    
</style>
