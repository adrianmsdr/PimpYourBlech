@page "/shop"
@using PimpYourBlech_BlazorApp.Components.Icons
@using PimpYourBlech_BlazorApp.Services
@using PimpYourBlech_ClassLibrary.Entities
@using PimpYourBlech_ClassLibrary.Services.Carts
@using PimpYourBlech_ClassLibrary.Services.Shop
@using PimpYourBlech_ClassLibrary.ValueObjects
@using Blazored.Toast
@using Blazored.Toast.Configuration
@using Blazored.Toast.Services
@using PimpYourBlech_ClassLibrary.Session
@inject NavigationManager Nav
@inject IImageService ImageService
@inject IShopService ShopService
@inject ICartService CartService
@inject IToastService ToastService
@inject IUserSession UserSession


<PageTitle>Shop</PageTitle>
<BlazoredToasts Position="ToastPosition.BottomRight" />
<h3 class="headline">Ersatzteile - Shop</h3>

<button type="button" class="GoToShoppingCart" @onclick="ToggleSidebar">
    <ShoppingCartIcon></ShoppingCartIcon> Warenkorb
</button>

@if (IsOpen)
{
    <div class="overlay" @onclick="ToggleSidebar"></div>
}

<div class="sidebar @(IsOpen ? "open" : "")">
    <div class="sidebar-header">
        <h2>Warenkorb</h2>
        <button class="close-btn" @onclick="ToggleSidebar">✕</button>
    </div>

    @if (CartService.CartProductsList == null || !CartService.CartProductsList.Any())
    {
        <div class="null-content">
            <button class="menu-item">Keine Produkte vorhanden</button>
        </div>
    }
    else
    {
        <div class="sidebar-content">
            @foreach (var item in CartService.CartProductsList)
            {
                <button class="menu-item">@item.Name – @item.Price.ToString("C")</button>
            }
            <u class="sum">Summe: @ShopService.GetTotalPrice(UserSession.CurrentUser.Id) €</u>
        </div>
    }
</div>
@*
Machen wir noch schön Bleibt nicht so aber im Prinzip holt der sich alle Produkte erstmal und zeigt sie mit
ausgewählten infos + bild in so nem Kästchen wär noch schön
- sollte man später auch anklicken können + warenkorb und alles drum und dran
*@

<div class="input-group mb-3">
    <input class="form-control"
           placeholder="Nach Artikelnummer, Name, Hersteller suchen..."
           @bind="searchText" />

    <button class="btn btn-primary" @onclick="ApplySearch">
        Suchen
    </button>
    
</div>
<div class="d-flex align-items-center mb-3 gap-3">

    @*Filter: Kategorie*@
    <div class="d-flex align-items-center">
        <label class="me-2 mb-0">Kategorie:</label>
        <select class="form-select" style="width: 200px"
                @bind="selectedCategory">
            <option value="All">Alle</option>
            <option value="Engine">Motor</option>
            <option value="Rim">Felge</option>
            <option value="Lights">Lichtanlage</option>
            <!-- weitere Kategorien später -->
        </select>
    </div>
    

    @*Sortierung*@
    <div class="d-flex align-items-center ms-auto">
        <label class="me-2 mb-0">Sortieren nach:</label>
        <select class="form-select" style="width: 220px"
                @bind="selectedSortOption">
            <option value="NameAscending">Name (A–Z)</option>
            <option value="NameDescending">Name (Z–A)</option>
            <option value="PriceAscending">Preis (aufsteigend)</option>
            <option value="PriceDescending">Preis (absteigend)</option>
        </select>
    </div>
</div>

@if (products == null)
{
    <p>Lade Produkte...</p>
}
else if (!products.Any())
{
    <p>Keine Produkte vorhanden.</p>
}
else
{
    <div class="product-grid">
        @foreach (var product in products)
        {
            <div class="product-card">
                <img src="@ImageService.GetProductImageUrl(product.ProductId)" 
                     alt="@product.Name" 
                     class="product-image" />
                <div class="product-info">
                    <h4>@product.Name</h4>
                    <p>@product.Brand</p>
                    <p class="product-price">@product.Price.ToString("C")</p>
                    <button type="button" class="selectProduct"
                            @onclick="() => AddToCart(product)">
                        <BuyIcon></BuyIcon> Kaufen
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Product> products;
    private string selectedCategory = "All";
    private string selectedSortOption = "NameAufsteigend";
    private string searchText = string.Empty;
    
    // Damit wird die methode automatisch aufgerufen beim laden der seite (also alle produkte geholt)
    protected override void OnInitialized()
    {
        LoadProducts();
    }
    //  |
    //  v
    public void LoadProducts()
    {
        products = ShopService.GetProducts();
    }
    
    private void ApplySearch()
    {
       products = ShopService.SearchProducts(searchText);
        
    }

    // Hier soll er sich später das Bild holen
    private string GetImage(Product p)
    {
        return string.IsNullOrWhiteSpace(p.ImageUrl)
            ? "/images/placeholder.png"
            : p.ImageUrl;
    }
    
    private bool IsOpen = false;

    private void ToggleSidebar()
    {
        IsOpen = !IsOpen;
    }
    
    private void AddToCart(Product product)
    {
        CartService.AddProduct(product);
        ToastService.ShowSuccess($"{product.Name} wurde zum Warenkorb hinzugefügt");
        StateHasChanged();
    }

    
    // Führt zum Hauptmenü
    private void Cancel()
    {
        Nav.NavigateTo("/mainMenu");
    }
}

