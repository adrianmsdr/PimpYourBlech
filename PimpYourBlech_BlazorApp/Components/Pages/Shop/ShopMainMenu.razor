@page "/shop"
@using PimpYourBlech_BlazorApp.Components.Icons
@using PimpYourBlech_BlazorApp.Services
@using PimpYourBlech_ClassLibrary.Entities
@using PimpYourBlech_ClassLibrary.Services.Carts
@using PimpYourBlech_ClassLibrary.Services.Shop
@using Blazored.Toast
@using Blazored.Toast.Configuration
@using Blazored.Toast.Services
@using PimpYourBlech_ClassLibrary.DTO
@using PimpYourBlech_ClassLibrary.Enums
@using PimpYourBlech_ClassLibrary.Services.Configurator
@using PimpYourBlech_ClassLibrary.Session
@using PimpYourBlech_ClassLibrary.Session.State
@using PimpYourBlech_ClassLibrary.ValueObjects
@inject NavigationManager Nav
@inject IImageService ImageService
@inject IShopService ShopService
@inject IConfiguratorService ConfiguratorService
@inject ICartService CartService
@inject IToastService ToastService
@inject IUserSession UserSession


<PageTitle>Shop</PageTitle>
<BlazoredToasts Position="ToastPosition.BottomRight"/>
<div class="shop-header">
    <img src="shopheader.png" class="header">
</div>

@if (IsOpen)
{
    <div class="overlay" @onclick="ToggleSidebar"></div>
    <div class="sidebar @(IsOpen ? "open" : "")">
        <div class="sidebar-header">
            <h2>Warenkorb</h2>
            <button class="close-btn" @onclick="ToggleSidebar">✕</button>
        </div>

        @if (!UserSession.CurrentCart.Products.Any())
        {
            <div class="null-content">
                <h4 class="headline-admin">Keine Produkte vorhanden</h4>
            </div>
        }
        else
        {
            <div class="sidebar-content">
                @foreach (var item in UserSession.CurrentCart.Products)
                {
                    <div class="cart-item">
                        <img src="@ImageService.GetProductImageUrl(item.ProductId)"
                             alt="@item.Product.Name"
                             class="cart-item-image" />

                        <p class="menu-item">
                            @item.Product.Name – Häufigkeit: @item.Quantity – @item.Price.ToString("C")
                        </p>
                        <p class="remove-icon" @onclick="() => RemoveItem(item)">❌</p>
                    </div>
                }

                <u class="sum">
                    Summe: @CartService.GetTotalPrice(UserSession.CurrentCart) €
                </u>

                <button class="checkout-button"
                        @onclick="NavigateToCheckout">
                    <ShoppingCartIcon /> Zur Kasse
                </button>
            </div>
        }
    </div>
}


@*
Machen wir noch schön Bleibt nicht so aber im Prinzip holt der sich alle Produkte erstmal und zeigt sie mit
ausgewählten infos + bild in so nem Kästchen wär noch schön
- sollte man später auch anklicken können + warenkorb und alles drum und dran
*@
<div class="search-container">
    
    <div class="search-row">
        <input class="search-input"
               placeholder="Nach Artikelnummer, Name, Hersteller suchen..."
               @bind="searchText"/>
        <button class="buttons" @onclick="LoadProductsAsync">
            Suchen <MagnifyingGlassIcon/>
        </button>
        <p class="GoToShoppingCart" @onclick="ToggleSidebar">
            <span class="cart-inside">
                @if (UserSession.CurrentCart.Products!=null)
                {
                    <span class="count">
                        @UserSession.CurrentCart.Products.Count
                    </span>
                }
                <span class="cart-icon">
                    <ShoppingCartIcon/>
                </span>
            </span>Warenkorb
        </p>
    </div>

    <div class="button-row">
    <div class="d-flex align-items-center gap-3">
        <label class="fields">Kategorie:</label>
        <select class="form-select" style="width: 200px"
                @bind="selectedCategory" @bind:after="LoadProductsAsync">
            <option value="">Alle</option>
            @foreach (var c in Enum.GetValues<ProductType>())
            {
                <option value="@c">@c</option>
            }
        </select>
       
        
    </div>

    <div class="d-flex align-items-center gap-3">
        <label class="fields">Sortieren nach:</label>
        <select class="form-select" style="width: 200px"
                @bind="selectedSortOption" @bind:after="LoadProductsAsync">
            <option value="@ProductSort.NameAsc">Standard</option>
            <option value="@ProductSort.NameAsc">Name (A–Z)</option>
            <option value="@ProductSort.NameDesc">Name (Z–A)</option>
            <option value="@ProductSort.PriceAsc">Preis (aufsteigend)</option>
            <option value="@ProductSort.PriceDesc">Preis (absteigend)</option>
        </select>
    </div>
    
    @if (cars != null)
    {
        <div class="d-flex align-items-center gap-3">
            <label class="fields">Fahrzeug:</label>

            <select class="form-select" style="width: 200px"
                    @bind="selectedCarId" @bind:after="LoadProductsAsync">

                <option value="0">Alle</option>

                @foreach (var c in cars)
                {
                    <option value="@c.Id">@c.Name</option>
                }
            </select>
        </div>
    }
    </div>


</div>


@if (products == null)
{
    <p>Lade Produkte...</p>
}
else if (!products.Any())
{
    <h4 class="headline-admin">Keine Produkte vorhanden.</h4>
}
else
{
    <div class="product-grid">
        @foreach (var product in products)
        {
            <a class="product-card">
                <img loading ="lazy" src="@ImageService.GetProductImageUrl(product.ProductId)"
                     @onclick="() => ShowProduct(product)"
                     class="product-image"/>
                <div class="product-info">
                    <h4 class="product-name"
                        @onclick="() => ShowProduct(product)">
                        @product.Name
                    </h4>
                    <p>@product.Brand</p>
                    <p class="product-price">@product.Price.ToString("C")</p>
                    <button type="button" class="selectProduct"
                            @onclick="() => AddToCart(product)">
                        <AddToCartIcon/> Zum Warenkorb
                    </button>
                </div>
            </a>
        }
    </div>
    }

<div class="marken-container">
    <img src="marken.png" class="marken-image">    
</div>

@code {
    private List<Product> products;
    private List<Car> cars;
    private ProductType? selectedCategory = null; // null = Alle
    private ProductSort selectedSortOption = ProductSort.NameAsc;
    private string searchText = string.Empty;
    private Product selectedProduct = new Product();
    private int selectedCarId = 0;
    private bool IsOpen = false;

    
    // Damit wird die methode automatisch aufgerufen beim laden der seite (also alle produkte geholt)
    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
       cars =  await ConfiguratorService.ListCarsAsync();
    }

    private async Task LoadProductsAsync()
    {
        var q = new ProductListQuery
        {
            Type = selectedCategory,
            SortBy = selectedSortOption,
            SearchTerm = string.IsNullOrWhiteSpace(searchText) ? null : searchText.Trim(),
            CarId = selectedCarId == 0 ? null : selectedCarId 
        };

        products = await ShopService.GetProductsAsync(q);
    }
    

    private void ToggleSidebar()
    {
        IsOpen = !IsOpen;
    }
    
    private void AddToCart(Product product)
    {
        UserSession.CurrentCart = CartService.AddProduct(UserSession.CurrentCart,product);
        ToastService.ShowSuccess($"{product.Name} wurde zum Warenkorb hinzugefügt");
        StateHasChanged();
    }

    private void RemoveItem(CartPosition product)
    {
        CartService.RemoveProduct(UserSession.CurrentCart,product);
        ToastService.ShowInfo($"{product.Product.Name} wurde aus dem Warenkorb entfernt");
        StateHasChanged();
    }

    private void NavigateToCheckout()
    {
        Nav.NavigateTo("/CheckoutPage");
    }
    
    
    private void ShowProduct(Product product)
    {
        Nav.NavigateTo($"/shop/details/{product.ProductId}");
    }
    
}
