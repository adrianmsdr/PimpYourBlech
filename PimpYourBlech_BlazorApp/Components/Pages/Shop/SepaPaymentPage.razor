@inject NavigationManager Nav

@page "/SepaPaymentPage"
@using PimpYourBlech_BlazorApp.Services.Toasts
@using PimpYourBlech_ClassLibrary.Services.Orders
@using PimpYourBlech_ClassLibrary.Session
@using PimpYourBlech_ClassLibrary.Session.Implementation
@using PimpYourBlech_Contracts.EntityDTOs
@inject IUserSession UserSession
@inject IOrderService OrderService
@inject IToastExecutor ToastExecutor
@inject ILogger<SepaPaymentPage> Logger


<div class="sepa-container">
    <h1 class="font">Kasse</h1>
<div class="mb-3">
    <select class="form-select" @bind="selectedPaymentValueId">
        <option value="0">Neue Zahlungsmethode</option>
        @foreach (var p in _paymentValues)
        {
            <option value="@p.Id">@p.AccountOwner,@p.Iban, @p.Bic</option>
        }
    </select>
    
  </div>
    <h5 class="font">Bitte gebe deine Bankdaten ein.</h5>
    <div class="mb-3">
        <input class="text-inputPYB"
               placeholder="Vorname"
               disabled="@isDisabled"
               @bind="surname"/>
    </div>
    
    <div class="mb-3">
        <input class="text-inputPYB"
               placeholder="Nachname"
               disabled="@isDisabled"
               @bind="lastname"/>
    </div>

    <div class="mb-3">
        <input class="text-inputPYB"
               placeholder="IBAN"
               disabled="@isDisabled"
               @bind="iban"/>
    </div>

    <div class="mb-3">
        <input class="text-inputPYB"
               placeholder="BIC"
               disabled="@isDisabled"
               @bind="bic"/>
    </div>
    
    <button class="buttons"
            disabled="@IsCheckoutDisabled"
            onclick="@NavigateToConfirm"
    >Weiter zur Bestätigung</button>
    
</div>

@code {
    private CustomerDto? c;
    private string surname  = string.Empty;
    private string lastname = string.Empty;
    private string iban     = string.Empty;
    private string bic      = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        c = await OrderService.GetCustomerByIdAsync(UserSession.CurrentUserId);
        _paymentValues = await OrderService.GetPaymentValuesAsync(c.Id);
        if (_paymentValues.Count >= 1){
            selectedPaymentValueId = _paymentValues[_paymentValues.Count-1].Id;
        }
    }


    private List<PaymentValueDto> _paymentValues = new();
    private int _selectedPaymentValueId;
    private bool IsCheckoutDisabled =>
        string.IsNullOrWhiteSpace(surname) ||
        string.IsNullOrWhiteSpace(lastname) ||
        string.IsNullOrWhiteSpace(iban) ||
        string.IsNullOrWhiteSpace(bic);

    
    private int selectedPaymentValueId
    {
        get => _selectedPaymentValueId;
        set
        {
            _selectedPaymentValueId = value;
            ApplySelectedPayment();
        }
    }

    private PaymentValueDto? SelectedPayment =>
        _paymentValues.FirstOrDefault(x => x.Id == selectedPaymentValueId);

    private bool isDisabled => SelectedPayment != null;

    private async Task NavigateToConfirm()
    { 
       
        Logger.LogInformation(
            "User {UserId} entered SEPA payment data and proceeds to confirmation",
            UserSession.CurrentUserId
        );

        
        if (SelectedPayment == null || selectedPaymentValueId == 0)
        {
            PaymentValueDto pv = new PaymentValueDto()
            {
                CustomerId = c.Id,
                AccountOwner = surname + " " + lastname,
                Bic = bic,
                Iban = iban
            };

           var pvId = await ToastExecutor.RunReturnAsync(()=>OrderService.InsertPaymentValueAsync(pv));
           if (pvId != 0)
           {
               UserSession.CurrentPaymentValueId = pvId;

               Logger.LogInformation(
                   "New payment value created for UserId={UserId}, PaymentId={PaymentId}",
                   UserSession.CurrentUserId,
                   pvId
               );
               Nav.NavigateTo("/ConfirmCheckoutPage");

           }
        }
        else
        {
            UserSession.CurrentPaymentValueId = SelectedPayment.Id;

            Logger.LogInformation(
                "Existing payment value selected for UserId={UserId}, PaymentId={PaymentId}",
                UserSession.CurrentUserId,
                SelectedPayment.Id
            );
            Nav.NavigateTo("/ConfirmCheckoutPage");

        }
    }
    
    private void ApplySelectedPayment()
    {
        var a = SelectedPayment;

        if (a is null)
        {
            surname     = string.Empty;
            lastname    = string.Empty;
            iban = string.Empty;
            bic = string.Empty;
            return;
        }
        
        surname     = a.AccountOwner;
        lastname    = a.AccountOwner;
        iban    = a.Iban;
       bic = a.Bic;
    }
}

<style>

    .sepa-container {
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 12px;
        width: 55%;
        height: 100%;
        padding: 25px;
        background: rgba(0, 0, 0, 0.25);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-radius: 18px;
        border: 1px solid rgba(255, 0, 0, 0.25);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.6);
    }
    .text-inputBYB {
        width: 240px;
        height: 38px;
        padding: 6px;
        font-family: Bahnschrift;
        text-align: center;
        background-color: rgba(20, 0, 0, 0.65);
        color: white;
        border-radius: 10px;
        border: 2px solid rgba(255, 0, 0, 0.6);
        outline: none;
        transition: 0.25s ease;
    }

    .text-inputBYB:hover {
        transform: scale(1.1);
    }

    .text-inputBYB:focus {
        border-color: #ff3333;
        box-shadow: 0 0 10px rgba(255, 50, 50, 0.6);
    }
    
    .font {
        color: white;
        font-family: Bahnschrift;
    }

    .buttons {
        width: 200px;
        height: 70px;
        font-family: Bahnschrift;
        font-size: 17px;
        color: white;
        background-color: #7a0000;
        border-radius: 12px;
        border: 2px solid #ff1a1a;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.6);
        cursor: pointer;
        transition:
            transform 0.25s ease,
            background-color 0.25s ease,
            box-shadow 0.25s ease;
    }

    .buttons:hover {
        transform: scale(1.1);
        background-color: #b30000;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.7);
    }

    .buttons:active {
        transform: scale(1.2);
    }

    .buttons:disabled {
        background-color: #4a4a4a;
        border-color: #777;
        color: #bbb;
        cursor: not-allowed;
        box-shadow: none;
        transform: none;
        opacity: 0.6;
    }

    .buttons:disabled:hover {
        transform: none;
        background-color: #4a4a4a;
        box-shadow: none;
    }

    .text-inputPYB:disabled {
        background-color: rgb(106, 2, 2);
    }
</style>