@page "/CheckoutPage"

@using PimpYourBlech_BlazorApp.Components.Icons
@using PimpYourBlech_BlazorApp.Services
@using PimpYourBlech_ClassLibrary.Services.Carts
@using PimpYourBlech_ClassLibrary.Services.Shop
@using PimpYourBlech_ClassLibrary.Session
@using Blazored.Toast.Services
@using PimpYourBlech_BlazorApp.Services.Images
@using PimpYourBlech_ClassLibrary.Services.Admin
@using PimpYourBlech_ClassLibrary.Services.Customers
@using PimpYourBlech_ClassLibrary.Services.Orders
@using PimpYourBlech_Contracts.EntityDTOs
@using PimpYourBlech_Data.Models
@inject NavigationManager Nav
@inject IImageService ImageService
@inject IShopService ShopService
@inject ICartService CartService
@inject IToastService ToastService
@inject IUserSession UserSession
@inject IOrderService OrderService
@inject IAdminService AdminService
@inject ILogger<CheckoutPage> Logger
@inject ICustomerService CustomerService


<div class="checkout-container">

@if (c is null)
    {
        <p class="font">Lade…</p>
    }
    else
    {
        <h1 class="font">Kasse</h1>
        <h5 class="font">Wohin sollen wir deine Bestellung liefern?</h5>

        <div class="mb-3">

            <select class="form-select" @bind="selectedDeliveryAddressId">
                <option value="0">Neue Lieferadrese</option>
                @foreach (var a in _addresses)
                {
                    <option value="@a.Id">@a.Lastname, @a.PostalCode, @a.Town, @a.Street @a.HouseNumber</option>
                }
            </select>

        </div>
        <div class="mb-3">
            <select class="text-inputPYB" @bind="salutation"
                    disabled="@isDisabled">
                <option value="">Anrede wählen</option>
                <option value="Herr">Herr</option>
                <option value="Frau">Frau</option>
                <option value="Divers">Divers</option>
            </select>
        </div>

        <div class="mb-3">
            <input class="text-inputPYB"
                   disabled="@isDisabled"
                   placeholder="Vorname"
                   @bind="surname"/>
        </div>

        <div class="mb-3">
            <input class="text-inputPYB"
                   disabled="@isDisabled"
                   placeholder="Nachname"
                   @bind="lastname"/>
        </div>

        <div class="mb-3">
            <input class="text-inputPYB"
                   disabled="@isDisabled"
                   placeholder="Straße"
                   @bind="street"/>
        </div>

        <div class="mb-3">
            <input class="text-inputPYB"
                   disabled="@isDisabled"
                   placeholder="Hausnummer"
                   @bind="housenumber"/>
        </div>

        <div class="mb-3">
            <input class="text-inputPYB"
                   disabled="@isDisabled"
                   placeholder="Ort"
                   @bind="town"/>
        </div>

        <div class="mb-3">
            <input class="text-inputPYB"
                   disabled="@isDisabled"
                   placeholder="Postleitzahl"
                   @bind="postalcode"/>
        </div>

        <div class="mb-3">
            <select class="text-inputPYB" @bind="country" disabled="@isDisabled">
                <option value="">Land wählen</option>
                <option value="DE">🇩🇪 Deutschland</option>
                <option value="AT">🇦🇹 Österreich</option>
                <option value="CH">🇨🇭 Schweiz</option>
            </select>
        </div>

            <button class="buttons"
                    onclick="@NavigateToConfirm">
                <CreditCardIcon/> Per Lastschrift bezahlen
            </button>
    }
</div>


@code {
    private CustomerDto? c;
    private string salutation  = string.Empty;
    private string surname     = string.Empty;
    private string lastname    = string.Empty;
    private string street      = string.Empty;
    private string housenumber = string.Empty;
    private string town        = string.Empty;
    private string postalcode  = string.Empty;
    private string country     = string.Empty;

    private List<DeliveryAddressDto> _addresses = new();
    private int _selectedDeliveryAddressId;

    private int selectedDeliveryAddressId
    {
        get => _selectedDeliveryAddressId;
        set
        {
            _selectedDeliveryAddressId = value;
            ApplySelectedAddress();
        }
    }

    private DeliveryAddressDto? SelectedAddress =>
        _addresses.FirstOrDefault(x => x.Id == selectedDeliveryAddressId);

    private bool isDisabled => SelectedAddress != null;

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation(
            "Checkout page opened by UserId={UserId}",
            UserSession.CurrentUserId
        );

       c = await AdminService.GetCustomerByIdAsync(UserSession.CurrentUserId);

      _addresses = await CustomerService.GetUserAddressesAsync(c.Id);

        if (_addresses.Count >= 1){
            selectedDeliveryAddressId = _addresses[_addresses.Count-1].Id;
        }
    }

    private async Task NavigateToConfirm()
    {
        Logger.LogInformation(
            "User {UserId} proceeds from checkout to payment",
            UserSession.CurrentUserId
        );

        if (SelectedAddress == null || selectedDeliveryAddressId == 0)
        {
            DeliveryAddressDto da = new DeliveryAddressDto
            {
                CustomerId = c.Id,
                Salutation = salutation,
                Surname = surname,
                Lastname = lastname,
                Street = street,
                HouseNumber = housenumber,
                Town = town,
                PostalCode = postalcode,
                Country = country
            };

       var    daId = await OrderService.InsertDeliveryAddressAsync(da);
            UserSession.CurrentDeliveryAddressId = daId;
            
            Logger.LogInformation(
                "New delivery address created for UserId={UserId}, AddressId={AddressId}",
                UserSession.CurrentUserId,
                daId
            );
        }
        else
        {
            UserSession.CurrentDeliveryAddressId = SelectedAddress.Id;

            Logger.LogInformation(
                "Existing delivery address selected for UserId={UserId}, AddressId={AddressId}",
                UserSession.CurrentUserId,
                SelectedAddress.Id
            );
        }

        Nav.NavigateTo("/SepaPaymentPage");
    }

    private void ApplySelectedAddress()
    {
        var a = SelectedAddress;

        if (a is null)
        {
            salutation  = string.Empty;
            surname     = string.Empty;
            lastname    = string.Empty;
            street      = string.Empty;
            housenumber = string.Empty;
            town        = string.Empty;
            postalcode  = string.Empty;
            country     = string.Empty;
            return;
        }

        salutation  = a.Salutation;
        surname     = a.Surname;
        lastname    = a.Lastname;
        street      = a.Street;
        housenumber = a.HouseNumber;
        town        = a.Town;
        postalcode  = a.PostalCode;
        country     = a.Country;
    }
}

<style>

    .checkout-container {
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 12px;
        width: 55%;
        height: 100%;
        padding: 25px;
        background: rgba(0, 0, 0, 0.25);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-radius: 18px;
        border: 1px solid rgba(255, 0, 0, 0.25);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.6);
    }
    .text-inputPYB:disabled {
        background-color: rgb(106, 2, 2);
    }

    .buttons {
        width: 200px;
        height: 70px;
        font-family: Bahnschrift;
        font-size: 17px;
        color: white;
        background-color: #7a0000;
        border-radius: 12px;
        border: 2px solid #ff1a1a;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.6);
        cursor: pointer;
        transition:
            transform 0.25s ease,
            background-color 0.25s ease,
            box-shadow 0.25s ease;
    }

    .buttons:hover {
        transform: scale(1.1);
        background-color: #b30000;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.7);
    }

    .buttons:active {
        transform: scale(1.2);
    }

    .buttons:disabled {
        background-color: #4a4a4a;
        border-color: #777;
        color: #bbb;
        cursor: not-allowed;
        box-shadow: none;
        transform: none;
        opacity: 0.6;
    }

    .buttons:disabled:hover {
        transform: none;
        background-color: #4a4a4a;
        box-shadow: none;
    }
    
    .font {
        color: white;
        font-family: Bahnschrift;
    }
    

</style>