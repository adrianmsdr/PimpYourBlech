@*<h3>ChooseComparable</h3>

@page "/compare/choose"

@using PimpYourBlech_BlazorApp.Services
@using PimpYourBlech_ClassLibrary.DTOs
@using PimpYourBlech_ClassLibrary.Services.Configurator
@inject IConfiguratorService ConfiguratorService
@inject IImageService ImageService

<h3>Fahrzeuge vergleichen</h3>
<p>Wähle mindestens zwei Fahrzeuge aus</p>

<table class="table table-striped">
    <thead>
    <tr>
        <th></th>
        <th>Bild</th>
        <th>Name</th>
        <th>Marke</th>
        <th>Modell</th>
        <th>Preis</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var car in cars)
    {
        <tr>
            <td>
                <input type="checkbox"
                       checked="@selectedCars.Any(c => c.Id == car.Id)"
                       disabled="@(selectedCars.Count >= MaxCompareItems && !selectedCars.Any(c => c.Id == car.Id))"
                       @onchange="() => ToggleCar(car)" />
            </td>
            <td>
                <img src="@ImageService.GetCarImageUrl(car.Id)"
                     style="width:120px; height:70px; object-fit:cover;" />
            </td>
            <td>@car.Name</td>
            <td>@car.Brand</td>
            <td>@car.Model</td>
            <td>@car.Price €</td>
        </tr>
    }
    </tbody>
</table>

<CarComparator SelectedCars="@selectedCars" />

@code {
    private const int MaxCompareItems = 3;

    private List<CarDto> cars = new();
    private List<CarDto> selectedCars = new();

    protected override async Task OnInitializedAsync()
    {
        cars = await ConfiguratorService.ListCarsAsync();
    }

    private void ToggleCar(CarDto car)
    {
        // bereits ausgewählt → entfernen
        if (selectedCars.Any(c => c.Id == car.Id))
        {
            selectedCars.RemoveAll(c => c.Id == car.Id);
            return;
        }

        // ❗ Limit erreicht → nichts hinzufügen
        if (selectedCars.Count >= MaxCompareItems)
        {
            return;
        }

        selectedCars.Add(car);
    }

}*@
