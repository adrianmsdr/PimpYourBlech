@page "/mainMenu"
@using PimpYourBlech_BlazorApp.Components.Icons
@using PimpYourBlech_ClassLibrary.Session
@inject NavigationManager Nav
@inject IUserSession UserSession
<PageTitle>Main Menu</PageTitle>

<div class="menu-container">
    <h2 class="headline-admin">Willkommen, @UserSession.CurrentUser.Username!</h2>

    @if (UserSession.CurrentUser.ImagePath != null)
    {
        <img src=@UserSession.CurrentUser.ImagePath class="user-image" @onclick="GoToUserSettings">
    }
    else
    {
        <img src="benutzer.png" class="user-image" @onclick="GoToUserSettings">

    }
    <div class="button-column">
        <div class="button-row-menu">
            <button class="btn-icon" @onclick="GoToConfigurator">
                <CarIcon />
            </button>

            <button class="btn-label" @onclick="GoToConfigurator">
                Konfiguration starten
            </button>
        </div>
        <div class="button-row-menu">
            <button class="btn-icon" @onclick="GoToComparator">
                <CarIcon />
            </button>

            <button class="btn-label" @onclick="GoToComparator">
                Fahrzeuge vergleichen
            </button>
        </div>
        <div class="button-row-menu">
            <button class="btn-icon" @onclick="GoToConfigurations">
                <CarIcon2 />
            </button>

            <button class="btn-label" @onclick="GoToConfigurations">
                Konfigurationen laden
            </button>
        </div>
        <div class="button-row-menu">
            <button class="btn-icon" @onclick="GoToShop">
                <ShopIcon />
            </button>

            <button class="btn-label" @onclick="GoToShop">
                Ersatzteile Shop
            </button>
        </div>

        <div class="button-row-menu">
            <button class="btn-icon" @onclick="GoToAdmin">
                <AdminIcon />
            </button>

            <button class="btn-label" @onclick="GoToAdmin">
                Administrator
            </button>
        </div>

        <div class="button-row-menu">
            <button class="btn-label2" @onclick="GoToFAQ">FAQ</button>
            <button class="btn-label2" @onclick="GoAboutUs">About Us</button>
        </div>
    </div>
</div>


@code
{
    private void GoToConfigurator() => Nav.NavigateTo("/configurator/chooseCar");

    private void GoToComparator() => Nav.NavigateTo("/compare/choose");
    
    private void GoToConfigurations() => Nav.NavigateTo("/configurations");

    private void GoToShop() => Nav.NavigateTo("/shop");
    
    private void GoToFAQ() => Nav.NavigateTo("/FAQ");
    
    private void GoAboutUs() => Nav.NavigateTo("/aboutUs");

    private void GoToUserSettings() => Nav.NavigateTo("/user");

    private void Logout()
    {
        UserSession.LogOut();
        Nav.NavigateTo("/");
    }

    private void GoToAdmin() => Nav.NavigateTo("/administrator");
}

<style>
    
    .user-image {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 2px solid rgba(255, 0, 0, 0.5);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.8);
    }
    .button-row-menu{
        display: flex;
        gap: 10px;
        /* margin-left: 50px;*/

        align-items: center;
    }

    /* linker Button: fix klein (Icon) */
    .btn-icon{
        width: 44px;
        height: 44px;
        padding: 0;

        display: flex;
        align-items: center;
        justify-content: center;

        font-family: Bahnschrift;
        font-size: 18px;
        color: white;
        /*
        background-color: #7a0000;
        */
        background-image: url("ButtonsImage.png");
        background-repeat: no-repeat;
        background-position: center;
        background-size: cover;
        border-radius: 12px;
        border: 2px solid #ff1a1a;
        box-shadow: 0 6px 16px rgba(0,0,0,0.6);
        transition: transform 0.25s ease, background-color 0.25s ease,
        box-shadow 0.25s ease, border-color 0.25s ease;
        cursor: pointer;


        flex-shrink: 0;
    }


    .btn-label{
        width: 220px;
        padding: 10px 20px;
        flex: 0 0 220px;
        height: 48px;
        font-family: Bahnschrift;
        font-size: 18px;
        color: white;

        background-image: url("ButtonsImage.png");
        background-repeat: no-repeat;
        background-position: center;
        background-size: cover;
        border-radius: 12px;
        border: 2px solid #ff1a1a;
        box-shadow: 0 6px 16px rgba(0,0,0,0.6);
        transition: transform 0.25s ease, background-color 0.25s ease,
        box-shadow 0.25s ease, border-color 0.25s ease;
        cursor: pointer;


    }



    .btn-label2{
        width: 132px;
        padding: 10px 20px;
        flex: 0 0 132px;

        height: 48px;
        font-family: Bahnschrift;
        font-size: 18px;
        color: white;

        background-image: url("ButtonsImage.png");
        background-repeat: no-repeat;
        background-position: center;
        background-size: cover;

        border-radius: 12px;
        border: 2px solid #ff1a1a;
        box-shadow: 0 6px 16px rgba(0,0,0,0.6);
        transition: transform 0.25s ease, background-color 0.25s ease,
        box-shadow 0.25s ease, border-color 0.25s ease;
        cursor: pointer;


    }
    .btn-label:hover,
    .btn-label2:hover
    {
        transform: scale(1.06);
        border-color: #ff4d4d;

        box-shadow:
            inset 0 0 0 1px rgba(255,255,255,0.14),
            0 10px 22px rgba(0,0,0,0.75);
    }

    .btn-label:active,
    .btn-label2:active{
        transform: scale(1.02);
    }


</style>