@page "/administrator/products/{id:int}"
<PageTitle>Administrator/products/@Id.ToString()</PageTitle>

@using PimpYourBlech_BlazorApp.Services
@using PimpYourBlech_ClassLibrary.Entities
@using PimpYourBlech_ClassLibrary.Enums
@using PimpYourBlech_ClassLibrary.Services.Admin
@inject IAdminService AdminService
@inject NavigationManager Nav
@inject IImageService ImageService
<h3>ShowCustomer</h3>
@if (Product == null)
{
    <p>Lade Daten…</p>
}
else
{
    <div class="card p-3">
        <p><strong>Name:</strong> @Product.Name</p>
        <p><strong>Artikelnummer:</strong> @Product.ArticleNumber</p>
        <p><strong>Hersteller:</strong> @Product.Brand</p>
        <p><strong>Preis:</strong> @Product.Price</p>
        <p><strong>Auf Lager:</strong> @Product.Quantity</p>
        <p><strong>Kategorie:</strong> @Product.ProductType</p>



        <div class="mt-3">
            <button class="btn btn-warning me-2" @onclick="LockCustomer">Bestand anpassen</button>
            <button class="btn btn-danger me-2"  @onclick="DeleteProduct">Fahrzeugteil löschen</button>
            <button class="btn btn-primary"       @onclick="EditProduct">Fahrzeugteil bearbeiten</button>
        </div>
    </div>
}
@code {
    [Parameter] public int Id { get; set; }

    public Product? Product { get; set; }

    protected override void OnInitialized()
    {
        Product = AdminService.GetProductById(Id);
    }

    private void LockCustomer()
    {
        // AdminService.LockCustomer(Customer)
    }

    private void DeleteProduct()
    {
        AdminService.DeleteProduct(Product);
        ImageService.DeleteProductImagesAsync(Product.ProductId);
        if (Product.ProductType == ProductType.Color)
        {
            ImageService.DeleteCarImagesAsync(Product.ProductId, Product.ColorDetail.CarId);
        }
        Nav.NavigateTo("/administrator/products");

    }

    private void EditProduct()
    {

    }
}