@page "/administrator/products/new"
<PageTitle>Administrator/products/new</PageTitle>
@using System.Runtime.CompilerServices
@using PimpYourBlech_BlazorApp.Services
@using PimpYourBlech_ClassLibrary.Entities
@using PimpYourBlech_ClassLibrary.Enums
@using PimpYourBlech_ClassLibrary.Services.Admin

@inject NavigationManager Nav
@inject IAdminService AdminService
@inject IImageService ImageService




<div class="menu-container">
    <h3 class="headline-admin">Neues Fahrzeugteil registrieren:</h3>

 @*Benachrichtigungen bei Fehlern oder als Bestätigung (Wird aktiviert falls die message gesetzt wird*@
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }
    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="alert alert-success">@_successMessage</div>
    }
    
    <div class="mb-3">
        <label class="form-label"><strong>Fahrzeug auswählen:</strong></label>

        <select class="form-select" @bind="_selectedCarId">
            <option value="0">-- Bitte wählen --</option>
            @foreach (var c in _cars)
            {
                <option value="@c.Id">@c.Name (@c.Id)</option>
            }
        </select>

        @if (_selectedCarId == 0)
        {
            <h4 class="headline-admin">Bitte wähle ein Fahrzeug aus.</h4>
        }
    </div>
    
    <div class="d-flex align-items-center">
        <span class="me-2">Produkttyp:</span>

        <select class="form-select me-2" style="width:auto"
                @bind="_selectedProductType">
            @foreach (ProductType T in _categories)
            {
                <option value="@T">@T</option>
            }
        </select>
    </div>

    @*Alle Eingabefelder (Daten werden mit @bind in Variable gespeichert zum Weiterverwenden)*@
    <input class="text-inputPYB"
           placeholder="Name"
           @bind="_name"/>
    

    <input class="text-inputPYB"
           placeholder="Hersteller..."
           @bind="_brand"/>

    
    <input class="text-inputPYB"
           placeholder="Bestand..."
           @bind="_quantity"/>

    <input class="text-inputPYB"
           placeholder="Preis..."
           @bind="_price"/>

    <textarea class="text-areaPYB"
          placeholder="Beschreibung (nur Shop)..."
          maxlength="1000"
          @bind="_description"></textarea>
    <div class="text-muted mt-1">@_description.Length / 1000</div>
    
    @if (_selectedProductType == ProductType.Motor)
    {
    <input class="text-inputPYB"
           placeholder="PS..."
           @bind="_ps"/>

    <input class="text-inputPYB"
           placeholder="KW..."
           @bind="_kw"/>

    <input class="text-inputPYB"
           placeholder="Hubraum..."
           @bind="_displacement"/>
    
    <span class="me-2">Getriebeart:</span>

    <select class="form-select me-2" style="width:auto"
            @bind="_selectedGear">
        <option value="5-Gang Manuell">5-Gang Manuell</option>
        <option value="6-Gang Manuell">6-Gang Manuell</option>
        <option value="6-Gang Automatik">6-Gang Automatik</option>
        <option value="8-Gang Automatik">8-Gang Automatik</option>
    </select>
    <select class="form-select me-2" style="width:auto"
            @bind="_selectedFuel">
        <option value="Benzin">Benzin</option>
        <option value="Diesel">Diesel</option>
        <option value="Hybrid">Hybrid</option>
        <option value="Gas">Gas</option>
        <option value="Elektro">Elektro</option>
    </select>
    
    }else if (_selectedProductType == ProductType.Felge)
    {
        
    <input class="text-inputPYB"
           placeholder="Durchmesser(Zoll)..."
           @bind="_diameter"/>

    <input class="text-inputPYB"
           placeholder="Breite(Zoll)..."
           @bind="_width"/>
   
    }

    else if (_selectedProductType == ProductType.Lichter)
    {
        <input class="text-inputPYB"
               placeholder="Lumen..."
               @bind="_lumen"/>

        <div class="mb-3">
            <span class="me-2">LED?:</span>

            <select class="form-select me-2" style="width:auto"
                    @bind="_isLed">
                <option value="True">Ja</option>
                <option value="False">Nein</option>
            </select>

        </div>

    }else if (_selectedProductType == ProductType.Lack)
    {
        <input class="text-inputPYB"
               placeholder="Farbenname"
               @bind="_displayName"/>
    }

    <div class="mb-3">
        <label><strong>Produktbild auswählen:</strong></label>
        <InputFile OnChange="HandleProductImageSelected" accept="image/*" />
    
        @if (_uploadedProductImage != null)
        {
            <div class="text-muted mt-1">1 Bild ausgewählt: @_uploadedProductImage.Name</div>
        }
    </div>

    
    <div class="button-column">
        <button class="buttons" @onclick="RegisterProduct">Fahrzeugteil registrieren</button>
        <button class="buttons" @onclick="Cancel">Abbrechen</button>
    </div>
</div>
@code {

    // Felder 
    private ProductType _selectedProductType = ProductType.Motor;
    private string _selectedGear = "6-Gang Manuell";
    public string _selectedFuel = "Benzin";
    private string _isLed = "True";
    private string _searchValue = string.Empty;

    private string _name = "";
    
    private string _brand = "";
    private string _quantity = "";
    private string _price = "";
    private string _description = "";

    private string _ps = "";
    private string _kw = "";
    private string _displacement = "";

    private string _diameter = "";
    private string _width = "";

    private string _lumen = "";

    private string _displayName = "";
    
    
    private IBrowserFile? _uploadedProductImage;

    private List<Car> _cars = new();
    private List<ProductType> _categories = new();
    private int _selectedCarId = 0;

    private string _errorMessage = "";
    private string _successMessage = "";

    protected override async Task OnInitializedAsync()
    {
        _cars = await AdminService.GetCarsAsync();
        _categories = AdminService.GetProductTypes();
    }

    private void HandleProductImageSelected(InputFileChangeEventArgs e)
    {
        _uploadedProductImage = e.File; // 
    }
    
    private async Task RegisterProduct()
    {
        _errorMessage = "";
        _successMessage = "";
        
        if (string.IsNullOrWhiteSpace(_name))
        {
            _errorMessage = "Name darf nicht leer sein.";
            return;
        }

        if (!int.TryParse(_quantity, out var quantityValue) || quantityValue < 0)
        {
            _errorMessage = "Bestand muss eine positive Ganzzahl sein.";
            return;
        }

        if (!double.TryParse(_price, out var priceValue) || priceValue < 0)
        {
            _errorMessage = "Preis muss eine positive Zahl sein.";
            return;
        }
        
        Product p = AdminService.CreateProduct(await AdminService.GetCarByIdAsync(_selectedCarId),_name, _brand, quantityValue, priceValue,_selectedProductType, _description);

        switch (_selectedProductType)
        {
            case ProductType.Motor:
                Fuel fuel = Fuel.Benzin;
                Gear gear = Gear.Manuell6Gang;
                if (string.IsNullOrWhiteSpace(_ps) || string.IsNullOrWhiteSpace(_kw) || string.IsNullOrWhiteSpace(_selectedGear))
                {
                    _errorMessage = "Bitte alle Motor-Details ausfüllen (PS, kW, Getriebeart).";
                    return;
                }

                if (!int.TryParse(_ps, out var psValue) || psValue < 0)
                {
                    _errorMessage = "PS muss eine positive Ganzzahl sein.";
                    return;
                }

                if (!int.TryParse(_kw, out var kwValue) || kwValue < 0)
                {
                    _errorMessage = "KW muss eine positive Ganzzahl sein.";
                    return;
                }

                switch (_selectedGear)
                {
                    case "5-Gang Manuell":
                        gear = Gear.Manuell5Gang;
                        break;

                    case "6-Gang Manuell":
                        gear = Gear.Manuell6Gang;
                        break;

                    case "6-Gang Automatik":
                        gear = Gear.Automatik6Gang;
                        break;

                    case "8-Gang Automatik":
                        gear = Gear.Automatik8Gang;
                        break;
                }

                switch (_selectedFuel)
                {
                    case "Benzin":
                        fuel = Fuel.Benzin;
                        break;

                    case "Diesel":
                        fuel = Fuel.Diesel;
                        break;

                    case "Hybrid":
                        fuel = Fuel.Hybrid;
                        break;

                    case "Gas":
                        fuel = Fuel.Gas;
                        break;


                    case "Elektro":
                        fuel = Fuel.Elektro;
                        break;
                }

                AdminService.RegisterEngine(p, psValue, kwValue, _displacement, gear, fuel);
                break;

            case ProductType.Felge:
                if (string.IsNullOrEmpty(_diameter) || string.IsNullOrEmpty(_width))
                {
                    _errorMessage = "Bitte Durchmesser und Breite der Felge ausfüllen.";
                    return;
                }

                if (!decimal.TryParse(_diameter, out var diameterValue) || diameterValue < 0)
                {
                    _errorMessage = "Durchmesser muss eine positive Zahl sein.";
                    return;
                }

                if (!decimal.TryParse(_width, out var widthValue) || widthValue < 0)
                {
                    _errorMessage = "Breite muss eine positive Zahl sein.";
                    return;
                }

                AdminService.RegisterRim(p, diameterValue, widthValue);
                break;

            case ProductType.Lichter:
                if (string.IsNullOrEmpty(_lumen))
                {
                    _errorMessage = "Bitte die Lumen-Anzahl für die Lichtanlage ausfüllen.";
                    return;
                }

                if (!int.TryParse(_lumen, out var lumenValue) || lumenValue < 0)
                {
                    _errorMessage = "Lumen muss eine positive Ganzzahl sein.";
                    return;
                }

                bool isLed = false;
                switch (_isLed)
                {
                    case "True":
                        isLed = true;
                        break;

                    case "False":
                        break;
                }

                AdminService.RegisterLights(p, lumenValue, isLed);
                break;

            case ProductType.Lack:
                AdminService.RegisterColor(p, _displayName);
                break;
        }
        p = await AdminService.InsertProduct( p);

        if (p.ProductId == 0)
        {
            _errorMessage = "Produkt konnte nicht gespeichert werden (keine gültige ID).";
            return;
        }

        if (_uploadedProductImage != null)
        {
            await ImageService.SaveProductImagesAsync(p.ProductId, _uploadedProductImage);
        }
        
        
        
        if (_uploadedProductImage != null)
        {
            await ImageService.SaveProductImagesAsync(p.ProductId, _uploadedProductImage);
        }

        _successMessage = "Fahrzeugteil erfolgreich registriert.";

     
    }

    private void Cancel()
    {
        Nav.NavigateTo("/administrator/products");
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrWhiteSpace(_searchValue))
        {
            return;
        }

        var term = _searchValue.Trim().ToLower();
    }


}

<style>
    /* 1) Texte/Labels besser lesbar */
    .menu-container label,
    .menu-container span,
    .menu-container strong,
    .menu-container .text-muted{
        font-family: Bahnschrift;
        color: rgba(255,255,255,.92);
        text-shadow: 0 2px 6px rgba(0,0,0,.65);
    }

    /* Bootstrap Utility me-2 / mb-3 etc. sind okay – wir machen nur Optik */
    .menu-container .me-2{
        font-weight: 700;
    }

    /* 2) SELECTS (Produkttyp/Getriebe/LED) auf dein Dark-Red-Design trimmen */
    .menu-container .form-select{
        width: 240px !important;                 /* gleiche Breite wie text-input */
        height: 38px !important;
        padding: 6px 38px 6px 10px !important;
        font-family: Bahnschrift !important;
        text-align: center;

        background-color: rgba(20, 0, 0, 0.65) !important;
        color: #fff !important;

        border-radius: 10px !important;
        border: 2px solid rgba(255, 0, 0, 0.6) !important;

        outline: none !important;
        box-shadow: none !important;

        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;

        transition: 0.25s ease;
    }

    /* Hover/Focus konsistent mit .text-input */
    .menu-container .form-select:hover{
        transform: scale(1.05);
    }
    .menu-container .form-select:focus{
        border-color: #ff3333 !important;
        box-shadow: 0 0 10px rgba(255, 50, 50, 0.6) !important;
    }

    /* Optionen im Dropdown nicht weiß */
    .menu-container .form-select option{
        background: #120000;
        color: #fff;
    }

    /* kleines Pfeil-Icon, damit’s nicht nach Default-Select aussieht */
    .menu-container .form-select{
        background-image:
            linear-gradient(45deg, transparent 50%, rgba(255,255,255,.75) 50%),
            linear-gradient(135deg, rgba(255,255,255,.75) 50%, transparent 50%);
        background-position:
            calc(100% - 18px) 55%,
            calc(100% - 12px) 55%;
        background-size: 6px 6px, 6px 6px;
        background-repeat: no-repeat;
    }

    /* 3) FILE INPUT (InputFile) anpassen, damit nix „weiß“ wirkt */
    .menu-container input[type="file"]{
        width: 240px;
        font-family: Bahnschrift;
        color: rgba(255,255,255,.9);

        background-color: rgba(20, 0, 0, 0.35);
        border: 2px dashed rgba(255, 0, 0, 0.45);
        border-radius: 10px;

        padding: 8px 10px;
    }

    /* Button im File-Input */
    .menu-container input[type="file"]::file-selector-button{
        font-family: Bahnschrift;
        border-radius: 10px;
        border: 2px solid rgba(255, 0, 0, 0.6);
        background: rgba(20, 0, 0, 0.65);
        color: #fff;
        padding: 6px 10px;
        cursor: pointer;
        transition: 0.25s ease;
    }
    .menu-container input[type="file"]::file-selector-button:hover{
        background: rgba(255, 0, 0, 0.22);
        transform: scale(1.05);
    }

    /* 4) Success/Error Alerts (falls Bootstrap-Alert zu grell/komisch) */
    .menu-container .alert{
        width: 240px;
        border-radius: 10px;
        font-family: Bahnschrift;
        text-align: center;
        border: 2px solid rgba(255, 0, 0, 0.35);
        background: rgba(0,0,0,.25);
        color: rgba(255,255,255,.92);
        text-shadow: 0 2px 6px rgba(0,0,0,.65);
    }
    .menu-container .alert-danger{
        border-color: rgba(255, 70, 70, 0.55);
    }
    .menu-container .alert-success{
        border-color: rgba(70, 255, 160, 0.35);
    }

    /* 5) TextInput Placeholder besser lesbar */
    .text-inputPYB::placeholder{
        color: rgba(255,255,255,.65);
    }

    .text-areaPYB{
        width: 380px;
        min-height: 140px;
        resize: vertical;
        font-family: Bahnschrift;
        text-align: left;
        background-color: rgba(20, 0, 0, 0.65);
        color: #fff;
        border-radius: 10px;
        border: 2px solid rgba(255, 0, 0, 0.6);
        padding: 10px;
        outline: none;
        transition: 0.25s ease;
    }

    .text-areaPYB:hover{
        transform: scale(1.05);
    }

    .text-areaPYB:focus{
        border-color: #ff3333;
        box-shadow: 0 0 10px rgba(255, 50, 50, 0.6);
    }

    .text-areaPYB::placeholder{
        color: rgba(255,255,255,.65);
    }

</style>