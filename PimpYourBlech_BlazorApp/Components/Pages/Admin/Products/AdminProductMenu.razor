@page "/administrator/products"
<PageTitle>Administrator/products</PageTitle>
@using PimpYourBlech_BlazorApp.Components.Icons
@using PimpYourBlech_ClassLibrary.Entities
@using PimpYourBlech_ClassLibrary.Services.Admin
@inject IAdminService AdminService
@inject NavigationManager Nav


<div class="menu-container">
    @if (filteredProducts == null || filteredProducts.Count == 0)
    {
        <p>Keine Fahrzeugteile vorhanden.</p>
    }
    else
    {

        <table class="table table-striped table-bordered">
            <thead>
            <tr>
                <th>Artikelnummer</th>
                <th>Name</th>
                <th>Hersteller</th>
                <th>Bestand</th>
            </tr>
            </thead>

            <tbody>
            @foreach (var p in filteredProducts)
            {
                <tr @onclick="@(() => Nav.NavigateTo($"/administrator/products/{p.ProductId}"))"
                    style="cursor: pointer;">
                    <td>@p.ArticleNumber</td>
                    <td>@p.Name</td>
                    <td>@p.Brand</td>
                    <td>@p.Quantity</td>
                </tr>
            }
            </tbody>
        </table>
    }
    @if (FoundProduct != null)
    {
        <div class="alert alert-info mt-3">
            <strong>Gefundenes Produkt:</strong><br />
            Artikelnummer: @FoundProduct.ArticleNumber <br />
            Name: @FoundProduct.Name <br />
            Hersteller: @FoundProduct.Brand <br />
            Bestand: @FoundProduct.Quantity
        </div>
    }

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger mt-3">@ErrorMessage</div>
    }

    <span class="mb-2">Suche nach:</span>

    <select class="form-select mb-2" style="max-width: 250px"
            @bind="selectedSearchField">
        <option value="Artikelnummer">Artikelnummer</option>
        <option value="Name">Name</option>
        <option value="Hersteller">Hersteller</option>
    </select>

    <input class="text-inputPYB"
           placeholder="Suchbegriff..."
           @bind="searchValue"
           @oninput="(e => ApplyFilter())"/>

    <div class="button-column">
        <button class="buttons" @onclick="ApplyFilter">
            <MagnifyingGlassIcon></MagnifyingGlassIcon>
            Nach Artikel suchen
        </button>

        <button class="buttons" @onclick="AddProduct">
            <AddIcon></AddIcon>
            Produkt hinzufügen
        </button>
        <button class="buttons" @onclick="Cancel">Zurück</button>
    </div>
</div>

@code {
    private List<Product> products = new();
    private List<Product> filteredProducts = new();

    private string selectedSearchField = "Name";
    private string searchValue = string.Empty;

    protected override void OnInitialized()
    {
        products = AdminService.GetProducts();
        filteredProducts = products.ToList();
    }

    private void AddProduct()
    {
        Nav.NavigateTo("/administrator/products/new");
    }

    private void ApplyFilter()
    {
        if (products == null || products.Count == 0)
        {
            filteredProducts = new List<Product>();
            return;
        }
        
        if (string.IsNullOrWhiteSpace(searchValue))
        {
            filteredProducts = products;
            return;
        }

        var term = searchValue.Trim().ToLower();


        filteredProducts = selectedSearchField switch
        {
            "Artikelnummer" => products
                .Where(p => p.ArticleNumber != null &&
                            p.ArticleNumber.ToLower().Contains(term))
                .ToList(),
            "Hersteller" => products
                .Where(p => p.Brand != null &&
                            p.Brand.ToLower().Contains(term))
                .ToList(),
            "Name" => products // Standard: Name
                .Where(p => p.Name != null &&
                            p.Name.ToLower().Contains(term))
                .ToList()
        };
    }
    
    private Product FoundProduct;
    private string ErrorMessage = "";
    
    private void Cancel()
    {
        Nav.NavigateTo("/administrator");
    }
}

