@page "/administrator/products/{id:int}/edit"
<PageTitle>Produkt bearbeiten</PageTitle>
@using Blazored.Toast
@using Blazored.Toast.Configuration
@using Blazored.Toast.Services
@using PimpYourBlech_BlazorApp.Services
@using PimpYourBlech_ClassLibrary.Entities
@using PimpYourBlech_ClassLibrary.Services.Admin
@inject IAdminService AdminService
@inject NavigationManager Nav
@inject IToastService ToastService
<BlazoredToasts Position="ToastPosition.BottomRight"/>

<div class="menu-container">
    <h3>Fahrzeugteil bearbeiten</h3>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <p style="color:#ffb3b3">@ErrorMessage</p>
    }
    @if (!string.IsNullOrWhiteSpace(SuccessMessage))
    {
        <p style="color:#bfffbf">@SuccessMessage</p>
    }

    @if (Product is null)
    {
        <p>Lade Daten…</p>
    }
    else
    {
        <div style="flex:1; min-width:320px;">
            <div class="combo-card-admin">
                <EditForm Model="EditModel" OnValidSubmit="SaveEdits">
                    <DataAnnotationsValidator/>
                    <ValidationSummary/>

                    <div class="form-grid-admin">
                        <label>Name:</label>
                        <InputText class="text-inputPYB form-input-grid" @bind-Value="EditModel.Name"/>

                        <label>Artikelnummer:</label>
                        <InputText class="text-inputPYB form-input-grid" @bind-Value="EditModel.ArticleNumber"/>

                        <label>Hersteller:</label>
                        <InputText class="text-inputPYB form-input-grid" @bind-Value="EditModel.Brand"/>

                        <label>Preis:</label>
                        <InputNumber class="text-inputPYB form-input-grid" @bind-Value="EditModel.Price"/>

                        <label>Auf Lager:</label>
                        <InputNumber class="text-inputPYB form-input-grid" @bind-Value="EditModel.Quantity"/>

                    </div>
                    
                    <div class="description-block-admin">
                        <div class="description-label-admin">Beschreibung</div>

                        <InputTextArea class="text-inputPYB form-textarea-admin"
                                       @bind-Value="EditModel.Description"
                                       rows="6" />
                    </div>
                    
                    <div class="button-column" style="margin-top:16px;">
                        <button type="submit" class="buttons">Speichern</button>
                        <button type="button" class="buttons" @onclick="Cancel">Zurück</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private Product? Product;
    private Product EditModel = new();

    private IBrowserFile? uploadedProductImage;

    private string ErrorMessage = "";
    private string SuccessMessage = "";

    protected override async Task OnInitializedAsync()
    {
        Product = await AdminService.GetProductByIdAsync(Id);
        if (Product is null)
        {
            ErrorMessage = "Produkt nicht gefunden.";
            return;
        }

        // Kopie fürs Formular (damit Cancel sauber ist)
        EditModel = new Product
        {
            ProductId = Product.ProductId,
            CarId = Product.CarId,
            Name = Product.Name,
            ArticleNumber = Product.ArticleNumber,
            Brand = Product.Brand,
            Price = Product.Price,
            Quantity = Product.Quantity,
            ProductType = Product.ProductType,
            Description = Product.Description
        };
    }


    private async Task SaveEdits()
    {
        if (Product is null) return;

        // Original updaten
        Product.Name = EditModel.Name;
        Product.ArticleNumber = EditModel.ArticleNumber;
        Product.Brand = EditModel.Brand;
        Product.Price = EditModel.Price;
        Product.Quantity = EditModel.Quantity;
        Product.ProductType = EditModel.ProductType;
        Product.Description = EditModel.Description;

        // Persistieren
        await AdminService.UpdateProductAsync(Product);
        ToastService.ShowSuccess("Änderungen wurden gespeichert.");
    }

    private void Cancel()
    {
        Nav.NavigateTo($"/administrator/products/{Id}");
    }

}
<style>
    .form-textarea-admin {
        margin-top: 20px;
        resize: vertical;

        width: 380px;
        min-height: 140px;
        line-height: 1.4;
        text-align: left;

    }
    .description-block-admin {
        margin-top: 20px;
        grid-column: 1 / -1;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .description-label-admin {
        text-align: center;
        font-weight: 600;
        opacity: 0.9;
    }
</style>