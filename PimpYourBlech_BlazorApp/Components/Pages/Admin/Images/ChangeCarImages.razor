@page "/administrator/images/360"
@using Blazored.Toast
@using Blazored.Toast.Configuration
@using Blazored.Toast.Services
@using PimpYourBlech_BlazorApp.Services.Images
@using PimpYourBlech_ClassLibrary.Services.Admin
@using PimpYourBlech_Contracts.EntityDTOs
@inject IAdminService AdminService
@inject IImageService ImageService
@inject NavigationManager Nav
@inject IToastService ToastService
@inject ILogger<ChangeCarImages> Logger
<BlazoredToasts Position="ToastPosition.BottomRight"/>
@if (isUploading)
{
    <div class="upload-overlay">
        <div class="upload-spinner">
            Bilder werden gespeichert…
        </div>
    </div>
}
<div class="menu-container wide">
<h3>Bildverwaltung</h3>

    <label><strong>Fahrzeug:</strong></label>
    <select class="form-select" value="@selectedCarId" @onchange="OnCarSelected">
        <option value="0">-- Bitte wählen --</option>
        @foreach (var c in cars)
        {
            <option value="@c.Id">@c.Name (@c.Id)</option>
        }
    </select>
    @if (selectedCarId == 0)
    {
        <div>Bitte wähle ein Fahrzeug aus.</div>
    }

    @if (selectedCarId != 0)
    {
        <hr/>

        <h4>Präsentationsbild:</h4>
        <img src="@ImageService.GetCarImageUrl(selectedCarId)" style="max-width:320px;border-radius:12px;"/>

        <div style="margin-top:10px">
            <InputFile OnChange="OnCarImageSelected" accept="image/*"/>
            <button class="buttons" @onclick="SaveCarImage" disabled="@(uploadedCarImage is null)">Speichern</button>
        </div>

        <hr/>

        <h4>360° Bilder</h4>

        @if (Colors.Count == 0 || Rims.Count == 0)
        {
            <div>Keine Varianten für dieses Fahrzeug gefunden.</div>
            <div style="padding:8px;border:1px dashed #666;margin-bottom:10px;">
                Debug:
                CarId=@selectedCarId |
                Colors=@Colors.Count |
                Rims=@Rims.Count
            </div>
        }
        else
        {
            @foreach (var c in Colors)
            {
                @foreach (var r in Rims)
                {
                    var frames = ImageService.Get360ImageUrls(selectedCarId, c.ProductId, r.ProductId);
                    var preview = frames.FirstOrDefault();

                    <div style="padding:12px;border:1px solid #444;border-radius:12px;margin-bottom:12px;">

                        <div class="combo-card-admin-grid">
                            <div class="combo-left">
                                @if (!string.IsNullOrWhiteSpace(preview))
                                {
                                    <img src="@preview" class="combo-preview"/>
                                }
                                else
                                {
                                    <div class="combo-empty">Keine Frames</div>
                                }
                            </div>

                            <div class="combo-right">
                                <div class="combo-header">
                                    <img class="combo-thumb" src="@ImageService.GetProductImageUrl(c.ProductId)"/>
                                    <span class="combo-plus">+</span>
                                    <img class="combo-thumb" src="@ImageService.GetProductImageUrl(r.ProductId)"/>
                                    <div class="combo-title">
                                        <div class="combo-name">@(c.Name) + @r.Name</div>
                                        <div class="combo-meta">Frames: @frames.Count • C:@c.ProductId /
                                            R:@r.ProductId</div>
                                    </div>
                                </div>

                                <div class="combo-upload">
                                    <label class="combo-label">360° Bilder auswählen (mehrere möglich)</label>
                                    <InputFile OnChange="HandleFilesSelected" multiple accept="image/*"/>
                                    @if (uploadedFiles.Count > 0)
                                    {
                                        <div class="combo-selected">@uploadedFiles.Count Datei(en) ausgewählt</div>
                                    }
                                </div>

                                <div class="combo-actions">
                                    <button class="btn btn-danger"
                                            @onclick="() => SaveColorFrames(c.ProductId, r.ProductId)"
                                            disabled="@(uploadedFiles.Count == 0)">
                                        Frames speichern
                                    </button>

                                    <button class="btn btn-outline-danger"
                                            @onclick="() => DeleteColorFrames(c.ProductId, r.ProductId)"
                                            disabled="@(frames.Count == 0)">
                                        Löschen
                                    </button>
                                </div>
                            </div>
                        </div>

                    </div>
                }
            }
            
        }
    }
</div>


@code {
    private CarDto car = new();
    private List<CarDto> cars = new();
    private List<ProductDto> Colors = new();
    private List<ProductDto> Rims = new();
    private int selectedCarId;

    private int CarId;

    private IBrowserFile? uploadedCarImage;
    private IReadOnlyList<IBrowserFile> uploadedFiles = Array.Empty<IBrowserFile>();
   
    private bool isUploading;
    private async Task OnCarSelected(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var id))
            return;

        if (selectedCarId == id) return;

        selectedCarId = id;

        Logger.LogInformation("Admin selected car for image management: CarId={CarId}", selectedCarId);

        await OnCarChangedAsync();
        StateHasChanged();
    }
    

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("Admin opened 360 image management page");
        cars = await AdminService.GetCarsAsync();
    }

    private void HandleFilesSelected(InputFileChangeEventArgs e)
    {
        uploadedFiles = e.GetMultipleFiles(40); //mehrere Bilder Speichern
    }

    private async Task OnCarChangedAsync()
    {
        uploadedCarImage = null;
        uploadedFiles = Array.Empty<IBrowserFile>();
           
        Colors.Clear();
        Rims.Clear();

        if (selectedCarId == 0) return;

        Colors = await AdminService.GetAvailableColors(selectedCarId);
        Rims = await AdminService.GetAvailableRims(selectedCarId);
    }

    private void OnCarImageSelected(InputFileChangeEventArgs e)
    {
       uploadedCarImage = e.File;
    }

    private async Task SaveCarImage()
    {
        if (selectedCarId == 0 || uploadedCarImage is null) return;

        await ImageService.SaveCarImageAsync(selectedCarId, uploadedCarImage);
        ToastService.ShowSuccess("Präsentationsbild wurde gespeichert.");
        
        Logger.LogInformation(
            "Admin uploaded car image for CarId={CarId}",
            selectedCarId
        );
        
    }
    
    private async Task SaveColorFrames(int colorId, int rimId)
    {
            if (isUploading) return;
            if (selectedCarId == 0) return;
            isUploading = true;
            StateHasChanged(); 
            
            Logger.LogInformation(
                "Admin started uploading 360 frames (CarId={CarId}, ColorId={ColorId}, RimId={RimId})",
                selectedCarId,
                colorId,
                rimId
            );

            

            try
            {
                await ImageService.Save360ImagesAsync(selectedCarId, colorId, rimId,uploadedFiles);
                ToastService.ShowSuccess("360°-Bilder gespeichert.");
                
                Logger.LogInformation(
                    "Admin successfully uploaded 360 frames (CarId={CarId}, ColorId={ColorId}, RimId={RimId})",
                    selectedCarId,
                    colorId,
                    rimId
                );

             
            }
            catch (Exception ex)
            {
                ToastService.ShowError(ex.Message);
                
                Logger.LogError(
                    ex,
                    "Error uploading 360 frames (CarId={CarId}, ColorId={ColorId}, RimId={RimId})",
                    selectedCarId,
                    colorId,
                    rimId
                );
            }
            finally
            {
                isUploading = false;
                StateHasChanged(); // Overlay weg
            }
        }
    
    private async Task DeleteColorFrames(int colorId, int rimId)
    {
        if (selectedCarId == 0) return;

        ImageService.Delete360ImagesAsync(selectedCarId, colorId, rimId);
           ToastService.ShowError("Frames wurden gelöscht"); 
           
           Logger.LogInformation(
               "Admin deleted 360 frames (CarId={CarId}, ColorId={ColorId}, RimId={RimId})",
               selectedCarId,
               colorId,
               rimId
           );
    }
    
}
<style>
    .upload-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        backdrop-filter: blur(6px);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: all; /* blockiert Klicks */
    }

    .upload-spinner {
        background: #111;
        color: #fff;
        padding: 24px 32px;
        border-radius: 12px;
        font-size: 1.1rem;
    }
    
</style>