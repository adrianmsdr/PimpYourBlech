@page "/administrator/orders"
<PageTitle>administrator/orders</PageTitle>

@using PimpYourBlech_BlazorApp.Components.Icons
@using PimpYourBlech_ClassLibrary.Services.Orders
@using PimpYourBlech_Contracts.DTOs
@using PimpYourBlech_Contracts.EntityDTOs
@inject NavigationManager Nav
@inject IOrderService OrderService


<div class="menu-container wide">
@if (orders == null || orders.Count == 0)
{
    <p>Keine Bestellungen vorhanden.</p>
}
else
{

    <table class="table table-striped table-bordered">
        <thead>
        <tr>
            <th>ID</th>
            <th>Zeitstempel</th>
            <th>Vorname</th>
            <th>Nachname</th>
            <th>Gesamtpreis</th>
        </tr>
        </thead>

        <tbody>
        @foreach (var o in orders)
        {
            <tr @onclick="@(() => Nav.NavigateTo($"/administrator/orders/{o.Id}"))"
                style="cursor: pointer">
                <td>@o.Id</td>
                <td>@o.Created</td>
                <td>@o.CustomerFirstName</td>
                <td>@o.CustomerLastName</td>
           
                <td>@o.TotalPrice€</td>
            </tr>
        }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger mt-3">@ErrorMessage</div>
}

<input class="text-inputPYB"
       placeholder="Order suchen..."
       @bind="searchValue" />
<div class="button-column">
    <button class="buttons" @onclick="Cancel">
        Suche nach Bestellung ...<MagnifyingGlassIcon></MagnifyingGlassIcon>
    </button>
    <button class="buttons" @onclick="Cancel">Zurück</button>

</div>

</div>

