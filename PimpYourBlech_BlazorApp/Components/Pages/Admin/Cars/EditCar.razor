@page "/administrator/cars/{id:int}/edit"
<PageTitle>Fahrzeug bearbeiten</PageTitle>
@using Blazored.Toast
@using Blazored.Toast.Configuration
@using Blazored.Toast.Services
@using PimpYourBlech_ClassLibrary.Services.Cars
@using PimpYourBlech_Contracts.EntityDTOs
@inject NavigationManager Nav
@inject IToastService ToastService
@inject ILogger<EditCar> Logger
@inject ICarService CarService


<BlazoredToasts Position="ToastPosition.BottomRight"/>

<div class="menu-container wide">
    <h3>Fahrzeug bearbeiten</h3>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <p style="color:#ffb3b3">@ErrorMessage</p>
    }
    @if (!string.IsNullOrWhiteSpace(SuccessMessage))
    {
        <p style="color:#bfffbf">@SuccessMessage</p>
    }

    @if (Car is null)
    {
        <p>Lade Daten…</p>
    }
    else
    {

            <div style="flex:1; min-width:320px;">
                <div class="combo-card-admin wide">
                    <EditForm Model="EditModel" OnValidSubmit="SaveEdits">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="form-grid-admin wide">
                            <label>Name</label>
                            <InputText class="text-inputPYB form-input-grid" @bind-Value="EditModel.Name" />

                            <label>Hersteller</label>
                            <InputText class="text-inputPYB form-input-grid" @bind-Value="EditModel.Brand" />

                            <label>Model</label>
                            <InputText class="text-inputPYB form-input-grid" @bind-Value="EditModel.Model" />

                            <label>Preis</label>
                            <InputNumber class="text-inputPYB form-input-grid" @bind-Value="EditModel.Price" />

                            <label>Auf Lager</label>
                            <InputNumber class="text-inputPYB form-input-grid" @bind-Value="EditModel.Quantity" />
                            
                            <label>Produktionsdatum</label>
                            <InputText class="text-inputPYB form-input-grid" @bind-Value="EditModel.DateProduction" />
                            
                            <label>Erstzulassung</label>
                            <InputText class="text-inputPYB form-input-grid" @bind-Value="EditModel.DatePermit" />
                            
                        </div>

                        <div class="button-column" style="margin-top:16px;">
                            <button type="submit" class="buttons">Speichern</button>
                            <button type="button" class="buttons" @onclick="Cancel">Zurück</button>
                        </div>
                    </EditForm>
                </div>
            </div>
      
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private CarDto? Car;
    private CarDto EditModel = new();
    
    
    private string ErrorMessage = "";
    private string SuccessMessage = "";

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation(
            "Admin opened edit page for CarId={CarId}",
            Id
        );
        
        Car = await CarService.GetCarByIdAsync(Id);
        if (Car is null)
        {
            Logger.LogWarning(
                "Admin tried to edit non-existing car with Id={CarId}",
                Id
            );
            
            ErrorMessage = "Fahrzeug nicht gefunden.";
            return;
        }

        // Kopie fürs Formular (damit Cancel sauber ist)
        EditModel = new CarDto
        {
            Id = Car.Id,
            Name = Car.Name,
            Brand = Car.Brand,
            DatePermit = Car.DatePermit,
            DateProduction = Car.DateProduction,
            Model = Car.Model,
            Price = Car.Price,
            PS = Car.PS,
            Quantity = Car.Quantity
        };
    }
    
    private async Task SaveEdits()
    {
        if (Car is null) return;
        
        Logger.LogInformation(
            "Admin started updating car with Id={CarId}",
            Car.Id
        );

        // Original updaten
        Car.Name = EditModel.Name;
        Car.Brand = EditModel.Brand;
        Car.Model = EditModel.Model;
        Car.Price = EditModel.Price;
        Car.Quantity = EditModel.Quantity;
        Car.DatePermit = EditModel.DatePermit;
        Car.DateProduction = EditModel.DateProduction;
        
        // Persistieren
        await CarService.UpdateCarAsync(Car);
        // Loggen
        Logger.LogInformation(
            "Admin successfully updated car with Id={CarId}",
            Car.Id
        );
        // User benachrichtigen
        ToastService.ShowSuccess("Änderungen wurden gespeichert.");
    }

    private void Cancel()
    {
        Logger.LogInformation(
            "Admin cancelled editing car with Id={CarId}",
            Car?.Id
        );
        
        Nav.NavigateTo($"/administrator/cars/{Car.Id}");
    }
}
