@page "/admin/cars/{id:int}"
@using PimpYourBlech_ClassLibrary.Entities
@using PimpYourBlech_ClassLibrary.Services.Admin
@rendermode InteractiveServer

@inject IAdminService AdminService
@inject  NavigationManager Nav
<h3>Ausgewähltes Fahrzeug:</h3>


@if (Car == null)
{
    <p>Lade Daten…</p>
}
else
{
    <div class="card p-3">
        <p><strong>Name:</strong> @Car.Name</p>
        <p><strong>Hersteller:</strong> @Car.Brand</p>
        <p><strong>Modell:</strong> @Car.Model</p>
        <p><strong>Preis:</strong> @Car.Price</p>
        <p><strong>Auf Lager:</strong> @Car.Quantity</p>

        <div class="mt-3">
            <button class="btn btn-warning me-2" @onclick="ChangeQuantity">Bestand anpassen</button>
            <button class="btn btn-danger me-2"  @onclick="DeleteProduct">Löschen</button>
            <button class="btn btn-primary"       @onclick="EditProduct">Bearbeiten</button>
        </div>
    </div>
}
@code {
    [Parameter] public int Id { get; set; }

    public Car? Car { get; set; }

    protected override void OnInitialized()
    {
        Car = AdminService.GetCarById(Id);
    }

    private void ChangeQuantity()
    {
        // AdminService.ChangeQuantityCar
    }

    private void DeleteProduct()
    {
        AdminService.DeleteCar(Car);
        Nav.NavigateTo("/admin/cars");
    }

    private void EditProduct()
    {

    }
}