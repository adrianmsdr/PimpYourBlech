@page "/administrator/cars/{id:int}"
<PageTitle>Administrator/cars/@Id.ToString()</PageTitle>
@using Blazored.Toast.Services
@using PimpYourBlech_BlazorApp.Services
@using PimpYourBlech_BlazorApp.Services.Images
@using PimpYourBlech_BlazorApp.Services.Toasts
@using PimpYourBlech_ClassLibrary.Services.Admin
@using PimpYourBlech_Contracts.EntityDTOs
@inject IToastService ToastService
@inject IToastExecutor ToastExecutor

@inject IAdminService AdminService
@inject  NavigationManager Nav
@inject IImageService ImageService
@if (showDeleteModal)
{
    <div class="pyb-backdrop" @onclick="CloseDeleteModal">
        <div class="pyb-modal" @onclick:stopPropagation="true">
            <h3 class="pyb-modal-title">Möchtest du das Fahrzeug wirklich löschen?</h3>
            <p class="pyb-modal-text">Diese Aktion kann nicht rückgängig gemacht werden.</p>

            <div class="pyb-modal-actions">
                <button class="buttons danger" @onclick="ConfirmDelete">Löschen</button>
                <button class="buttons" @onclick="CloseDeleteModal">Abbrechen</button>
            </div>
        </div>
    </div>
}


<div class="menu-container wide">
<h3>Fahrzeugübersicht:</h3>


@if (Car == null)
{
    <p>Lade Daten…</p>
}
else
{
    
    <div class="detail-overview-admin">
        <img class="detail-image-admin" src="@ImageService.GetCarImageUrl(Car.Id)" />

        <div class="upload-row-admin">
            <InputFile OnChange="OnCarImageSelected" accept="image/*" />
            <button class="buttons" @onclick="SaveCarImage" disabled="@(uploadedCarImage is null)">
                Speichern
            </button>
        </div>
        <div class="combo-card-admin wide">
        <div class="section">
        <h5 class="section-title">Fahrzeugdetails</h5>
        <div class="admin-details-section-divider"></div>
        <div class="admin-detail-grid wide">
            <div class="k">Name</div>
            <div class="v">@Car.Name</div> 
            <div class="k">Hersteller</div>
            <div class="v">@Car.Brand</div> 
            <div class="k">Modell</div>
            <div class="v">@Car.Model</div> 
            <div class="k">Preis</div>
            <div class="v">@Car.Price</div> 
            <div class="k">Auf Lager</div>
            <div class="v">@Car.Quantity</div>
        </div>
    </div>
    </div>
   
        <div class="button-column">
            <button class="buttons" @onclick="OpenDeleteModal">Fahrzeug löschen</button>
            <button class="buttons" @onclick="EditCar">Fahrzeug bearbeiten</button>
            <button class="buttons" @onclick="Cancel">Zurück</button>
        </div>
    </div>
}
</div>
@code {
    [Parameter] public int Id { get; set; }

    public CarDto? Car { get; set; }

    private IBrowserFile? uploadedCarImage;

    private string ErrorMessage = "";
    private string SuccessMessage = "";
    
    protected override async Task OnInitializedAsync()
    {
        Car = await AdminService.GetCarByIdAsync(Id);
    }

    private void OnCarImageSelected(InputFileChangeEventArgs e)
    {
        uploadedCarImage = e.File;
    }
    

    private async Task SaveCarImage()
    {
        if (Car.Id == 0 || uploadedCarImage is null) return;

        await ImageService.SaveCarImageAsync(Car.Id, uploadedCarImage);
        SuccessMessage = "Präsentationsbild gespeichert.";
    }

    private void EditCar()
    {
        Nav.NavigateTo($"/administrator/cars/{Car.Id}/edit");
    }

    private void Cancel()
    {
        Nav.NavigateTo($"/administrator/cars");
    }
    
    private bool showDeleteModal;

    void OpenDeleteModal() => showDeleteModal = true;
    void CloseDeleteModal() => showDeleteModal = false;

    async Task ConfirmDelete()
    {
        var id = Car.Id;
        if (await ToastExecutor.RunAsync(() => AdminService.DeleteCarAsync(Car)))
        {
            bool success = ImageService.DeleteCarImagesAsync(id);
            if (!success)
            {
                ToastService.ShowError("Fehler beim Löschen der Fahrzeugbilder");
            }
        }

        showDeleteModal = false;
        Nav.NavigateTo("/administrator/cars");
        
       

    }
}