@page "/administrator/cars"
<PageTitle>Administrator/cars</PageTitle>
@using PimpYourBlech_BlazorApp.Components.Icons
@using PimpYourBlech_ClassLibrary.DTO
@using PimpYourBlech_ClassLibrary.Entities
@using PimpYourBlech_ClassLibrary.Enums
@using PimpYourBlech_ClassLibrary.Services.Admin
@inject NavigationManager Nav
@inject IAdminService AdminService

<div class="menu-container wide">

    <div class="search-container">

        <div class="search-row">
            <input class="search-input"
                   placeholder="Nach Modell, Name, Hersteller suchen..."
                   @bind="searchText"/>
            <button class="buttons" @onclick="ApplyFilter">
                Suchen
                <MagnifyingGlassIcon/>
            </button>
        </div>
        <div class="button-row">
            <div class="d-flex align-items-center gap-3">
                <label class="fields">Sortieren nach:</label>
                <select class="form-select" style="width: 200px"
                        @bind="selectedSortOption" @bind:after="ApplyFilter">
                    <option value="@ProductSort.NameAsc">Standard</option>
                    <option value="@ProductSort.NameAsc">Name (A–Z)</option>
                    <option value="@ProductSort.NameDesc">Name (Z–A)</option>
                    <option value="@ProductSort.PriceAsc">Preis (aufsteigend)</option>
                    <option value="@ProductSort.PriceDesc">Preis (absteigend)</option>
                </select>
            </div>
        </div>
    </div>
    @if (cars == null || cars.Count == 0)
    {
        <p>Keine Fahrzeuge vorhanden.</p>
    }
    else
    {
        <table class="table table-striped table-bordered">
            <thead>
            <tr>
                <th>Name</th>
                <th>Hersteller</th>
                <th>Modell</th>
                <th>Preis</th>
                <th>Bestand</th>
            </tr>
            </thead>

            <tbody>
            @foreach (var c in cars)
            {
                <tr @onclick="@(() => Nav.NavigateTo($"/administrator/cars/{c.Id}"))"
                    style="cursor: pointer;">
                    <td>@c.Name</td>
                    <td>@c.Brand</td>
                    <td>@c.Model</td>
                    <td>@c.Price</td>
                    <td>@c.Quantity</td>
</tr>
            }
            </tbody>
        </table>
    }
    <div class="button-column">
<button class="buttons" @onclick="AddCar">
            <AddIcon></AddIcon>
            Fahrzeug hinzufügen
        </button>
        <button class="buttons" @onclick="Cancel">Zurück</button>
    </div>
</div>
@code {
    private List<Car> cars = new();
    private Car FoundCar;
    private string searchText = string.Empty;
    private string selectedSearchField = "Name";
    private CarSort selectedSortOption = CarSort.NameAsc;

    protected override async Task OnInitializedAsync()
    {
        cars = await AdminService.GetCarsAsync();
    }

    private void AddCar()
    {
        Nav.NavigateTo("/administrator/cars/new");
    }

    private void Cancel()
    {
        Nav.NavigateTo("/administrator/");
    }

    private async Task ApplyFilter()
    {
        var q = new CarListQuery()
        {
            SortBy = selectedSortOption,
            NameContains = string.IsNullOrWhiteSpace(searchText) ? null : searchText.Trim(),
        };
        cars = await AdminService.CarListQueryAsync(q);
    }

}
    <style>
        .search-container {
            width: 100%;
        }
    </style>
