@page "/admin/cars"
@using PimpYourBlech_ClassLibrary.Entities
@using PimpYourBlech_ClassLibrary.Services.Admin
@inject NavigationManager Nav
@inject IAdminService AdminService
<PageTitle>Administrator/cars</PageTitle>

<h3>AdminCarMenu</h3>
<table class="table table-striped table-bordered">
    <thead>
    <tr>
        <th>Name</th>
        <th>Hersteller</th>
        <th>Modell</th>
        <th>Preis</th>
        <th>Bestand</th>
    </tr>
    </thead>

    <tbody>
    @foreach (var c in cars)
    {

        <tr @onclick="@(() => Nav.NavigateTo($"/admin/cars/{c.Id}"))"
            style="cursor: pointer;">
            <td>@c.Name</td>
            <td>@c.Brand</td>
            <td>@c.Model</td>
            <td>@c.Price</td>
            <td>@c.Quantity</td>

        </tr>
    }
    </tbody>
</table>

<div class="mt-3 border-top pt-3">
    <div class="d-flex align-items-center">
        <span class="me-2">Suche nach:</span>

        <select class="form-select me-2" style="width:auto"
                @bind="selectedSearchField">
            <option value="Artikelnummer">Artikelnummer</option>
            <option value="Name">Name</option>
            <option value="Hersteller">Hersteller</option>
        </select>

        <input class="form-control me-2"
               style="max-width: 250px"
               placeholder="Suchbegriff..."
               @bind="searchValue"
        />

        <button class="btn btn-primary" @onclick="AddCar">
            +
        </button>
    </div>
</div>

@code {
    private List<Car> cars = new();
    private List<Car> filteredCars = new();

    private string selectedSearchField = "Name";
    private string searchValue = string.Empty;

    protected override void OnInitialized()
    {
        cars = AdminService.GetCars();
    }

    private void AddCar()
    {
        Nav.NavigateTo("/admin/cars/new");
    }

}