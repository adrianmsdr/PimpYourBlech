@page "/administrator/customers/{id:int}"
<PageTitle>Administrator/customers/@Id.ToString()</PageTitle>
@using PimpYourBlech_ClassLibrary.Services.Admin
@using PimpYourBlech_ClassLibrary.Services.Configurator
@using PimpYourBlech_ClassLibrary.Services.Customers
@using PimpYourBlech_ClassLibrary.Services.Orders
@using PimpYourBlech_Contracts.DTOs
@using PimpYourBlech_Contracts.EntityDTOs
@inject IAdminService AdminService
@inject ICustomerService CustomerService
@inject IConfiguratorService ConfiguratorService
@inject IOrderService OrderService
@inject NavigationManager Nav

@if (showDeleteModal)
{
    <div class="pyb-backdrop" @onclick="CloseDeleteModal">
        <div class="pyb-modal" @onclick:stopPropagation="true">
            <h3 class="pyb-modal-title">Möchtest du den User wirklich löschen?</h3>
            <p class="pyb-modal-text">Diese Aktion kann nicht rückgängig gemacht werden.</p>

            <div class="pyb-modal-actions">
                <button class="buttons danger" @onclick="ConfirmDelete">Löschen</button>
                <button class="buttons" @onclick="CloseDeleteModal">Abbrechen</button>
            </div>
        </div>
    </div>
}

<div class="menu-container wide">
    
    <h1 class="headline-admin">Kundenübersicht</h1>

    @if (p == null)
    {
        <p>Lade Daten…</p>
    }
    else
    {
        <div class="detail-overview-admin">
            <div class="combo-card-admin wide">
                <div class="section">
                    <h5 class="section-title">Nutzerdaten</h5>
                    <div class="admin-details-section-divider"></div>

                    <div class="admin-detail-grid wide">
                        <div class="k">ID</div>
                        <div class="v">@p.Id</div>
                        <div class="k">Username</div>
                        <div class="v">@p.Username</div>
                        <div class="k">Administrator</div>
                        <div class="v">@p.AdminRights</div>
                    </div>
                </div>

                <div class="section">
                    <h5 class="section-title">Persönliche Daten</h5>
                    <div class="admin-details-section-divider"></div>

                    <div class="admin-detail-grid wide">
                        <div class="k">Vorname</div>
                        <div class="v">@p.FirstName</div>
                        <div class="k">Nachname</div>
                        <div class="v">@p.LastName</div>
                        <div class="k">E-Mail</div>
                        <div class="v">@p.MailAddress</div>
                        <div class="k">Telefon</div>
                        <div class="v">@p.Telefon</div>
                    </div>
                </div>
            </div>
            <div class="combo-card-admin wide">
                <div class="section">
                    <h5 class="section-title">Registrierte Lieferadressen</h5>
                    <div class="admin-details-section-divider"></div>
                    @if (DeliveryAddressDtos != null)
                    {
                        <table class="table table-striped table-bordered">
                            <thead>
                            <tr>
                                <th>Anrede</th>
                                <th>Vorname</th>
                                <th>Nachname</th>
                                <th>Postleitzahl</th>
                                <th>Ort</th>
                                <th>Straße</th>
                                <th>Hausnummer</th>
                                <th>Land</th>
                            </tr>
                            </thead>

                            <tbody>
                            @foreach (var d in DeliveryAddressDtos)
                            {
                                <tr >
                                    <td>@d.Salutation</td>
                                    <td>@d.Surname</td>
                                    <td>@d.Lastname</td>
                                    <td>@d.PostalCode</td>
                                    <td>@d.Town</td>
                                    <td>@d.Street</td>
                                    <td>@d.HouseNumber</td>
                                    <td>@d.Country</td>
                                </tr>
                            }
                            </tbody>
                        </table>

                    }

                    else
                    {
                        <div class="admin-details-section-divider"></div>
                        <p>
                            <h4 class="headline-admin">Registrierte Lieferadresse</h4>
                            Keine Lieferadresse Registriert ...
                        </p>


                    }

                </div>
            </div>

            <div class="combo-card-admin wide">
                <div class="section">
                    <h5 class="section-title">Bestellungen</h5>
                    <div class="admin-details-section-divider"></div>

                    @if (OrderDtos == null || OrderDtos.Count == 0)
                    {
                        <p>Keine Bestellungen vorhanden.</p>
                    }
                    else
                    {

                        <table class="table table-striped table-bordered">
                            <thead>
                            <tr>
                                <th>ID</th>
                                <th>Zeitstempel</th>
                                <th>Gesamtpreis</th>
                            </tr>
                            </thead>

                            <tbody>
                            @foreach (var o in OrderDtos)
                            {
                                <tr @onclick="@(() => Nav.NavigateTo($"/administrator/orders/{o.OrderId}"))"
                                    style="cursor: pointer">
                                    <td>@o.OrderId</td>
                                    <td>@o.OrderDate</td>
                                    <td>@o.TotalPrice€</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    }
                </div>
            </div>





            <div class="combo-card-admin wide">
                <div class="section">
                    <h5 class="section-title">Konfigurationen</h5>
                    <div class="admin-details-section-divider"></div>



                    @if (ConfigurationDtos == null || ConfigurationDtos.Count == 0)
                    {
                        <p>Keine Konfigurationen vorhanden.</p>
                    }
                    else
                    {

                        <table class="table table-striped table-bordered">
                            <thead>
                            <tr>
                                <th>Name</th>
                                <th>Auto</th>
                                <th>Anzahl Produkte</th>
                            </tr>
                            </thead>

                            <tbody>
                            @foreach (var c in ConfigurationDtos)
                            {
                                <tr @onclick="@(() => Nav.NavigateTo($"/configurator/{c.CarId}/?configId={c.ConfigurationId}"))"
                                    style="cursor: pointer">
                                    <td>@c.Name</td>
                                    <td>@c.CarName</td>
                                    <td>@c.ProductCount</td>
                                </tr>
                            }
                            </tbody>
                        </table>

                    }
                </div>

            </div>
        </div>
        <div class="button-column">
            <button class="buttons" @onclick="LockCustomer">Sperren</button>
            <button class="buttons" @onclick="OpenDeleteModal">Löschen</button>
            <button class="buttons" @onclick="EditCustomer">Bearbeiten</button>
            <button class="buttons" @onclick="Cancel">Zurück</button>
        </div>

    }
</div>



@code {
    [Parameter] public int Id { get; set; }
    public List<ConfigurationCarItemsDto> ConfigurationDtos = new List<ConfigurationCarItemsDto>();
    public List<DeliveryAddressDto> DeliveryAddressDtos = new List<DeliveryAddressDto>();
    public List<OrderDto> OrderDtos = new List<OrderDto>();
    public CustomerDto? p { get; set; }

    protected override async Task OnInitializedAsync()
    {
        p = await AdminService.GetCustomerByIdAsync(Id);
        ConfigurationDtos = await ConfiguratorService.GetConfigurationsBasicsCustomerAsync(p.Id);
        DeliveryAddressDtos = await CustomerService.GetUserAddressesAsync(p.Id);
        OrderDtos = await OrderService.GetUserOrdersAsync(p.Id);
    }

    private void LockCustomer()
    {
        // AdminService.LockCustomer(Customer)
    }


    private void EditCustomer()
    {
        Nav.NavigateTo($"/administrator/customers/{p.Id}/edit");
        
    } 
    
    private void Cancel()
    {
        Nav.NavigateTo("/administrator/customers");
    }
    
    private bool showDeleteModal;

    void OpenDeleteModal() => showDeleteModal = true;
    void CloseDeleteModal() => showDeleteModal = false;

    async Task ConfirmDelete()
    {
        await AdminService.DeleteCustomerAsync(p);
        showDeleteModal = false;
        Nav.NavigateTo("/administrator/customers");

    }
}
<style>
    .combo-card-wide {
        width: min(450px);
    }
</style>