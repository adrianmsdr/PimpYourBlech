@page "/administrator/customers"
<PageTitle>Administrator/customers</PageTitle>
@using PimpYourBlech_BlazorApp.Components.Icons
@using PimpYourBlech_ClassLibrary.Services.Admin
@using PimpYourBlech_Contracts.EntityDTOs
@using PimpYourBlech_Contracts.Enums
@using PimpYourBlech_Contracts.Query
@inject IAdminService AdminService
@inject NavigationManager Nav


<div class="menu-container wide">
    
    
    
    <div class="search-container">

        <div class="search-row">
            <input class="search-input"
                   placeholder="Nach Namen..."
                   @bind="searchText"/>
            <button class="buttons" @onclick="ApplyFilter">
                Suchen
                <MagnifyingGlassIcon/>
            </button>
        </div>
        <div class="button-row">
            <div class="d-flex align-items-center gap-3">
                <label class="fields">Sortieren nach:</label>
                <select class="form-select" style="width: 200px"
                        @bind="selectedSortOption" @bind:after="ApplyFilter">
                    <option value="@CustomerSort.NameAsc">Standard</option>
                    <option value="@CustomerSort.NameAsc">Name (A–Z)</option>
                    <option value="@CustomerSort.NameDesc">Name (Z–A)</option>
                   
                </select>
            </div>
        </div>
    </div>

    @if (customers == null || customers.Count == 0)
    {
        <p>Keine Nutzer vorhanden.</p>
    }
    else
    { 
        <table class="table table-striped table-bordered">
            <thead>
            <tr>
                <th>Vorname</th>
                <th>Nachname</th>
                <th>Username</th>
                <th>Email</th>
            </tr>
            </thead>

            <tbody>
            @foreach (var c in customers)
            {
                <tr @onclick="@(() => Nav.NavigateTo($"/administrator/customers/{c.Id}"))"
                    style="cursor: pointer">
                    <td>@c.FirstName</td>
                    <td>@c.LastName</td>
                    <td>@c.Username</td>
                    <td>@c.MailAddress</td>
                </tr>
            }
            </tbody>
        </table>
    }

    <div class="button-column">
      <button class="buttons" @onclick="Cancel">Zurück</button>
    </div>

</div>

@code {
    private List<CustomerDto> customers = new List<CustomerDto>();
    private string searchValue = string.Empty;
    private CustomerDto FoundCustomer;
    private CustomerSort selectedSortOption = CustomerSort.NameAsc;
    private string searchText = string.Empty;

    
    
    protected override async Task OnInitializedAsync()
    {
        customers = await AdminService.GetListCustomersAsync();
    }



    private async Task ApplyFilter()
    {
        var q = new CustomerListQuery()
        {
            SortBy = selectedSortOption,
            SearchTerm = string.IsNullOrWhiteSpace(searchText) ? null : searchText.Trim(),
        };
        customers = await AdminService.GetFilteredCustomersAsync(q);
    }

    private void Cancel()
    {
        Nav.NavigateTo("/administrator/");
    }
}
