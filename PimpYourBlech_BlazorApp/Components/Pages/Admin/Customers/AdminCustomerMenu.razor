@page "/administrator/customers"
<PageTitle>Administrator/customers</PageTitle>
@using PimpYourBlech_BlazorApp.Components.Icons
@using PimpYourBlech_ClassLibrary.Entities
@using PimpYourBlech_ClassLibrary.Services.Admin
@inject IAdminService AdminService
@inject NavigationManager Nav


<div class="blur-container">
@if (customers == null || customers.Count == 0)
{
    <p>Keine Nutzer vorhanden.</p>
}
else
{

    <table class="table table-striped table-bordered">
        <thead>
        <tr>
            <th>Vorname</th>
            <th>Nachname</th>
            <th>Username</th>
            <th>Email</th>
        </tr>
        </thead>

        <tbody>
        @foreach (var c in customers)
        {
            <tr @onclick="@(() => Nav.NavigateTo($"/administrator/customers/{c.Id}"))"
                style="cursor: pointer">
                <td>@c.FirstName</td>
                <td>@c.LastName</td>
                <td>@c.Username</td>
                <td>@c.MailAddress</td>
            </tr>
        }
        </tbody>
    </table>
}
@if (FoundCustomer != null)
{
    <div class="alert alert-info mt-3">
        <strong>Gefunden:</strong><br />
        Vorname: @FoundCustomer.FirstName <br />
        Nachname: @FoundCustomer.LastName <br />
        Username: @FoundCustomer.Username <br />
        Email: @FoundCustomer.MailAddress
    </div>
}

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger mt-3">@ErrorMessage</div>
}

<input class="text-inputPYB"
       placeholder="Username suchen..."
       @bind="searchValue" />
<div class="button-column">
    <button class="buttons" @onclick="SearchUsername">
        Suche nach User <MagnifyingGlassIcon></MagnifyingGlassIcon>
    </button>
    <button class="buttons" @onclick="Cancel">Zurück</button>

</div>

</div>

@code {
    private List<Customer> customers = new List<Customer>();

    protected override void OnInitialized()
    {
        customers = AdminService.GetListCustomers();
    }

    private string searchValue = string.Empty;
    private Customer FoundCustomer;
    private string ErrorMessage = "";

    private void SearchUsername()
    {
        if (customers == null || customers.Count == 0)
        {
            return;
        }
        FoundCustomer = null;
        ErrorMessage = "";

        foreach (var c in customers)
        {
            if (c.Username == searchValue)
            {
                FoundCustomer = c;
                ErrorMessage = "";
                return;
            }
        }

        ErrorMessage = "Kein Benutzer mit diesem Username gefunden.";
        StateHasChanged();
    }

    private void Cancel()
    {
        Nav.NavigateTo("/administrator/");
    }
}
