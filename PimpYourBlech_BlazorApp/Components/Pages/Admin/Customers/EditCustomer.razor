@page "/administrator/customers/{id:int}/edit"

<PageTitle>User bearbeiten</PageTitle>
@using Blazored.Toast
@using Blazored.Toast.Configuration
@using Blazored.Toast.Services
@using PimpYourBlech_BlazorApp.Services
@using PimpYourBlech_ClassLibrary.Services.Admin
@using PimpYourBlech_Contracts.EntityDTOs
@inject IAdminService AdminService
@inject NavigationManager Nav
@inject IToastService ToastService
@inject ILogger<EditCustomer> Logger

<BlazoredToasts Position="ToastPosition.BottomRight"/>

<div class="menu-container">
    <h3>User bearbeiten</h3>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <p style="color:#ffb3b3">@ErrorMessage</p>
    }
    @if (!string.IsNullOrWhiteSpace(SuccessMessage))
    {
        <p style="color:#bfffbf">@SuccessMessage</p>
    }

    @if (Customer is null)
    {
        <p>Lade Daten…</p>
    }
    else
    {

            <div style="flex:1; min-width:320px;">
                <div class="combo-card-admin">
                    <EditForm Model="EditModel" OnValidSubmit="SaveEdits">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="form-grid-admin">
                            <label>Vorname</label>
                            <InputText class="text-inputPYB form-input-grid" @bind-Value="EditModel.FirstName" />

                            <label>Nachname</label>
                            <InputText class="text-inputPYB form-input-grid" @bind-Value="EditModel.LastName" />

                            <label>E-Mail</label>
                            <InputText class="text-inputPYB form-input-grid" @bind-Value="EditModel.MailAddress" />

                            <label>Telefon</label>
                            <InputText class="text-inputPYB form-input-grid" @bind-Value="EditModel.Telefon" />

                            <label>Passwort</label>
                            <InputText class="text-inputPYB form-input-grid" type="password" @bind-Value="EditModel.PasswordHash" />
                            
                            <label>Username</label>
                            <InputText class="text-inputPYB form-input-grid" @bind-Value="EditModel.Username" />
                     
                            @* <label>Admin-Rechte</label>
                            <div class="text-inputPYB form-input-grid checkbox-box">
                                <InputCheckbox class="admin-checkbox" @bind-Value="EditModel.AdminRights" />
                            </div>*@
                        
                            </div>

                        <div class="button-column" style="margin-top:16px;">
                            <button type="submit" class="buttons">Speichern</button>
                            <button type="button" class="buttons" @onclick="Cancel">Zurück</button>
                        </div>
                    </EditForm>
                </div>
            </div>
      
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private CustomerDto? Customer;
    private CustomerDto EditModel = new();

    private string ErrorMessage = "";
    private string SuccessMessage = "";

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation(
            "Admin opened edit page for CustomerId={CustomerId}",
            Id
        );
        
        Customer = await AdminService.GetCustomerByIdAsync(Id);
        if (Customer is null)
        {
            Logger.LogWarning(
                "Admin tried to edit non-existing customer with Id={CustomerId}",
                Id
            );
            
            ErrorMessage = "User nicht gefunden.";
            return;
        }

        // Kopie fürs Formular (damit Cancel sauber ist)
        EditModel = new CustomerDto()
        {
           Id = Customer.Id,
           FirstName = Customer.FirstName,
           LastName = Customer.LastName,
           AdminRights = Customer.AdminRights, 
           MailAddress = Customer.MailAddress,
           Telefon = Customer.Telefon,
           PasswordHash = Customer.PasswordHash,
           Username = Customer.Username
        };
    }
    
    private async Task SaveEdits()
    {
        if (Customer is null) return;

        // 🔹 LOG: Admin speichert Änderungen am Customer
        Logger.LogInformation(
            "Admin started updating customer with Id={CustomerId}",
            Customer.Id
        );

        // Persistieren (muss existieren)
        await AdminService.UpdateCustomerAsync(EditModel);

        // 🔹 LOG: Update erfolgreich
        Logger.LogInformation(
            "Admin successfully updated customer with Id={CustomerId}",
            Customer.Id
        );

        ToastService.ShowSuccess("Änderungen wurden gespeichert.");
    }

    private void Cancel()
    {
        // 🔹 LOG: Admin bricht Bearbeiten ab
        Logger.LogInformation(
            "Admin cancelled editing customer with Id={CustomerId}",
            Id
        );

        Nav.NavigateTo($"/administrator/customers/{Id}");
    }
}
<style>
    .checkbox-box{
        display:flex;
        align-items:center;
        justify-content:center;
    }

    .admin-checkbox{
        width:18px;
        height:18px;
        accent-color:#e50000; 
    }
</style>
