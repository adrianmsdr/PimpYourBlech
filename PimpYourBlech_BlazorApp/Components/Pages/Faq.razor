@page "/FAQ"

@using PimpYourBlech_ClassLibrary.Services.FAQ
@using PimpYourBlech_ClassLibrary.Entities

@inject IFaqService FaqService

<!-- Hero Header -->
<div class="hero-header d-flex align-items-center mb-5">
    <div class="container-fluid text-white text-center">
        <h1 class="display-4 fw-bold">FAQ & Community</h1>
        <p class="lead">
            Antworten auf häufige Fragen und Austausch mit der Community
        </p>
    </div>
</div>

    <h4>Häufig gestellte Fragen</h4>
    <div class="accordion accordion-flush">
        @foreach (var item in AccordionItems)
        {
            <div class="form-control accordion-item mb-3">
                <h2 class="box-control accordion-header">
                    <button class="back-control accordion-button @(item.IsOpen ? "" : "collapsed")" @onclick="() => Toggle(item)">
                        @item.Title
                    </button>
                </h2>
                <div class="accordion-collapse @(item.IsOpen ? "show" : "collapse")">
                    <div class="border-akkordion accordion-body">
                        @item.Content
                    </div>
                </div>
            </div>
        }
    </div>


<br/>
<h4>Community Fragen</h4>

<!-- Formular zum Posten einer Frage -->
<div class="mb-4">
    <textarea class="form-control mb-2" placeholder="Stelle deine Frage..." @bind="NewQuestionContent"></textarea>
    <button class="btn btn-primary" @onclick="PostQuestion">Frage posten</button>
</div>

<!-- Liste der Fragen -->
@foreach (var question in CommunityQuestions)
{
    <div class="form-control card mb-2">
        <div class="card-body">
            <p>@question.Content</p>
            <small class="faq-timestamp">@question.CreatedAt.ToString("g")</small>
            
            <!-- Toggle Button -->
            <button class="btn btn-link p-0 mt-2"
                    @onclick="() => ToggleAnswers(question.Id)">
                @(IsAnswersOpen(question.Id)
                    ? "Antworten ausblenden"
                    : $"Antworten anzeigen ({question.Answers.Count})")
            </button>

            <!-- Antworten zu dieser Frage -->
            @if (IsAnswersOpen(question.Id) && question.Answers != null)
            {
                <div class="mt-2 ms-3">
                    @foreach (var answer in question.Answers)
                    {
                        <div class="form-control card mb-1">
                            <div class="card-body">
                                <p>@answer.Content</p>
                                <small class="faq-timestamp">@answer.CreatedAt.ToString("g")</small>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Antwortformular -->
            @if (!NewAnswerContent.ContainsKey(question.Id))
            {
                NewAnswerContent[question.Id] = "";
            }
            <input type="text" class="form-control mb-1"
                   placeholder="Antwort hinzufügen..."
                   @bind="NewAnswerContent[question.Id]" />
                <button class="btn btn-primary btn-sm" @onclick="() => PostAnswer(question.Id)">Antwort posten</button>
            </div>
        </div>
}

@code {
    // ______________Akordeon auf der Seite_____________________
    private List<AccordionItem> AccordionItems = new()
    {
        // Hier können Häufig Gestelte Fragen Angepasst werden
        new AccordionItem { Title = "Ich habe Schwierigkeiten bei meiner Zahlung, was tun?", 
                            Content = (MarkupString)@"Ganz einfach bei unserem Support unter <a href=""mailto:pimpyourblech@gmail.com"">pimpyourblech@gmail.com</a> melden, Ihre Anliegen sind uns wichtig!"},
        new AccordionItem { Title = "Von wo kommen die Fahrzeuge?", 
                            Content = (MarkupString)@"Wir sind Vertragspartner die ihren Service an Autohändler und Hersteller vermieten und die gesamte abwicklung für Sie übernehmen." },
        new AccordionItem { Title = "Bietet Ihr keine E-Fahrzeuge an?", 
                            Content = (MarkupString)@"E-Fahrzeuge werden unserer Produktspanne bald hinzugefügt." }
    };

    private void Toggle(AccordionItem item)
    {
        //Nur ein Item offen lassen
        foreach (var i in AccordionItems)
            i.IsOpen = false;

        item.IsOpen = !item.IsOpen;
    }

    private class AccordionItem
    {
        public string Title { get; set; }
        public MarkupString Content { get; set; }
        public bool IsOpen { get; set; }
        //----------------------------------------------------
    }
    //------------------Comunity FAQ----------------------
    
    private List<CommunityQuestion> CommunityQuestions = new();
    private string NewQuestionContent;
    private Dictionary<int, string> NewAnswerContent = new();

    protected override async Task OnInitializedAsync()
    {
        CommunityQuestions = await FaqService.GetCommunityQuestionsAsync();
        foreach (var q in CommunityQuestions)
        {
            if (!NewAnswerContent.ContainsKey(q.Id))
                NewAnswerContent[q.Id] = "";
        }

    }

    private async Task PostQuestion()
    {
        if (!string.IsNullOrWhiteSpace(NewQuestionContent))
        {
            await FaqService.AddCommunityQuestionAsync(NewQuestionContent);
            NewQuestionContent = "";
            CommunityQuestions = await FaqService.GetCommunityQuestionsAsync();
        }
    }

    private async Task PostAnswer(int questionId)
    {
        if (NewAnswerContent.ContainsKey(questionId) && !string.IsNullOrWhiteSpace(NewAnswerContent[questionId]))
        {
            await FaqService.AddCommunityAnswerAsync(questionId, NewAnswerContent[questionId]);
            NewAnswerContent[questionId] = "";
            CommunityQuestions = await FaqService.GetCommunityQuestionsAsync();
        }
    }
    //----------Ausklappfunktion der Fragen--------------
    private HashSet<int> OpenAnswerQuestions = new();

    private void ToggleAnswers(int questionId)
    {
        if (!OpenAnswerQuestions.Add(questionId))
            OpenAnswerQuestions.Remove(questionId);
    }

    private bool IsAnswersOpen(int questionId)
    {
        return OpenAnswerQuestions.Contains(questionId);
    }
    
    }
}
