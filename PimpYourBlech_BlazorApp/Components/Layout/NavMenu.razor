@rendermode InteractiveServer

@using TestAutoKonfigurator.Session
@inject NavigationManager Nav
@inject IUserSession UserSession

<nav class="align-content-around">
    <div style="color: yellow; font-size: 12px;">
        Debug: @(UserSession.CurrentUser == null ? "kein User" : UserSession.CurrentUser.Username)
    </div>
    <div class="top-row ps-3 navbar navbar-dark">
        @if (!UserSession.IsLoggedIn)
        {
            <!-- Menü vor dem Login -->
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/login">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Anmelden
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/register">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Registrieren
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/aboutus">
                    <span class="bi bi-info-circle-fill-nav-menu" aria-hidden="true"></span> Über uns
                </NavLink>
            </div>
        }
        else
        {
            <!-- Hauptmenü nach Login -->
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/main">
                    <span class="bi bi-play-fill-nav-menu" aria-hidden="true"></span> Konfiguration starten
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/config/load">
                    <span class="bi bi-folder2-open-nav-menu" aria-hidden="true"></span> Konfiguration laden
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/shop">
                    <span class="bi bi-shop-nav-menu" aria-hidden="true"></span> Ersatzteileshop
                </NavLink>
            </div>

            @if (UserSession.IsAdmin)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/admin">
                        <span class="bi bi-gear-fill-nav-menu" aria-hidden="true"></span> Administrator
                    </NavLink>
                </div>
            }

            <div class="nav-item px-3">
                <a class="nav-link" href="" @onclick="Logout">
                    <span class="bi bi-box-arrow-right-nav-menu" aria-hidden="true"></span>
                    Abmelden (@UserSession.CurrentUser?.Username)
                </a>
            </div>
        }



        @code {

            private void Logout()
            {
                UserSession.LogOut();
                // zurück zur Startseite, Sidebar springt automatisch auf "nicht eingeloggt"
                Nav.NavigateTo("/start", forceLoad: true);
            }

        }

    </div>
</nav>